<sect1 id="mgba" xreflabel="mGBA-&mgba-minor-version;">
  <?dbhtml filename="mgba.html"?>

  <title>mGBA-&mgba-minor-version;</title>

  <indexterm zone="mgba">
    <primary sortas="a-mgba">mGBA</primary>
  </indexterm>

  <sect2 role="package">
    <title>Introduction to mGBA</title>

    <para>
      The <application>mGBA</application> package provides a GBA emulator. It
      can also be used with other emulators.
    </para>

    <itemizedlist spacing="compact">
      <listitem>
        <para>
          Download (HTTP): <ulink url="&mgba-download-http;"/>
        </para>
      </listitem>
    </itemizedlist>

    <bridgehead renderas="sect3">mgba Dependencies</bridgehead>

    <bridgehead renderas="sect4">Required</bridgehead>
    <para role="required">
      <ulink url="&blfs-svn;/general/cmake.html">CMake</ulink>,
      <ulink url="&blfs-svn;/x/libepoxy.html">libepoxy</ulink>,
      <ulink url="&blfs-svn;/general/libpng.html">libpng</ulink>, and
      <xref linkend="libzip"/>
    </para>

    <bridgehead renderas="sect4">Recommended</bridgehead>
    <para role="recommended">
      <ulink url="&blfs-svn;/general/desktop-file-utils.html">desktop-file-utils</ulink>,
      <ulink url="&blfs-svn;/multimedia/ffmpeg.html">FFmpeg</ulink>,
      <ulink url="&blfs-svn;/general/lua.html">Lua</ulink>,
      <ulink url="&blfs-svn;/x/qt6.html">Qt-6</ulink> and/or
      <ulink url="&blfs-svn;/multimedia/sdl2.html">SDL2</ulink> (for the
      frontends), and
      <ulink url="&blfs-svn;/server/sqlite.html">SQLite</ulink>
    </para>

    <bridgehead renderas="sect4">Optional</bridgehead>
    <para role="optional">
      <ulink url="&arch-pkgs;/core/x86_64/libedit/">editline</ulink>
    </para>

  </sect2>

  <sect2 role="installation">
    <title>Installation of mGBA</title>

    <para>
      Install <application>mGBA</application> by running the following
      commands:
    </para>

<screen><userinput>mkdir build &amp;&amp;
cd    build &amp;&amp;

cmake -D CMAKE_INSTALL_PREFIX=/usr   \
      -D CMAKE_BUILD_TYPE=Release    \
      -D CMAKE_SKIP_INSTALL_RPATH=ON \
      -G Ninja .. &amp;&amp;

ninja</userinput></screen>

    <para>
      Now, as the &root; user:
    </para>

<screen role="root"><userinput>ninja install &amp;&amp;
mv -v /usr/share/doc/mGBA{,-&mgba-minor-version;}</userinput></screen>

  </sect2>
  
  <sect2 role="commands">
    <title>Command Explanations</title>

    <xi:include xmlns:xi="http://www.w3.org/2001/XInclude"
      href="../../../xincludes/cmake-skip-install-rpath.xml"/>

    <para>
      <command>mv -v /usr/share/doc/mGBA{,-&mgba-minor-version;}</command>: This
      command ensures the doc folder for this package is consistent with the
      other packages.
    </para>

  </sect2>

  <sect2 role="content">
    <title>Contents</title>

    <segmentedlist>
      <segtitle>Installed Programs</segtitle>
      <segtitle>Installed Libraries</segtitle>
      <segtitle>Installed Directories</segtitle>

      <seglistitem>
        <seg>
          mgba and mgba-qt
        </seg>
        <seg>
          libmgba
        </seg>
        <seg>
          /usr/include/mgba{,-util} and /usr/share/doc/mgba-&mgba-minor-version;
        </seg>
      </seglistitem>
    </segmentedlist>

    <variablelist>
      <bridgehead renderas="sect3">Short Descriptions</bridgehead>
      <?dbfo list-presentation="list"?>
      <?dbhtml list-presentation="table"?>

      <varlistentry id="mgba-bin">
        <term><command>mgba</command></term>
        <listitem>
          <para>
            is the <application>SDL2</application> frontend for
            <application>mGBA</application>
          </para>
          <indexterm zone="mgba mgba-bin">
            <primary sortas="b-mgba-bin">mgba</primary>
          </indexterm>
        </listitem>
      </varlistentry>

      <varlistentry id="mgba-qt">
        <term><command>mgba-qt</command></term>
        <listitem>
          <para>
            is the <application>Qt-6</application> frontend for
            <application>mGBA</application>
          </para>
          <indexterm zone="mgba mgba-qt">
            <primary sortas="b-mgba-qt">mgba-qt</primary>
          </indexterm>
        </listitem>
      </varlistentry>

      <varlistentry id="libmgba">
        <term><filename class="libraryfile">libmgba</filename></term>
        <listitem>
          <para>
            contains the <application>mGBA</application> core which can be
            used by frontends and other emulators
          </para>
          <indexterm zone="mgba libmgba">
            <primary sortas="c-libmgba">libmgba</primary>
          </indexterm>
        </listitem>
      </varlistentry>

    </variablelist>

  </sect2>

