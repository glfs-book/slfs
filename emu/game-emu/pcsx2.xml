  <sect2 role="package">
    <title>Introduction to PCSX2</title>

    <para>
      The PCSX2 package provides a PlayStation 2 (PS2) emulator.
    </para>

    &long-build-time;

    <itemizedlist spacing="compact">
      <listitem>
        <para>
          Download: <ulink url="&pcsx2-download;"/>
        </para>
      </listitem>
    </itemizedlist>

    <bridgehead renderas="sect3">Additional Downloads</bridgehead>
    <itemizedlist spacing="compact">
      <listitem>
        <para>
          Recommended game patch collection:
          <ulink url="https://github.com/PCSX2/pcsx2_patches/releases/download/latest/patches.zip"/>
        </para>
      </listitem>
    </itemizedlist>

    <bridgehead renderas="sect3">pcsx2 Dependencies</bridgehead>

    <bridgehead renderas="sect4">Required</bridgehead>
    <para role="required">
      <ulink url="&blfs-svn;/general/cmake.html">CMake</ulink>,
      <ulink url="&blfs-svn;/basicnet/curl.html">cURL</ulink>,
      <ulink url="&blfs-svn;/general/dbus.html">D-Bus</ulink>,
      &ecm;,
      <ulink url="&blfs-svn;/multimedia/ffmpeg.html">FFmpeg</ulink>,
      <ulink url="&blfs-svn;/general/freetype2.html">FreeType2</ulink>,
      <ulink url="&blfs-svn;/basicnet/libpcap.html">libpcap</ulink>,
      <ulink url="&blfs-svn;/general/libpng.html">libpng</ulink>,
      <ulink url="&blfs-svn;/general/libjpeg.html">libjpeg-turbo</ulink>,
      <ulink url="&blfs-svn;/general/libwebp.html">libwebp</ulink>,
      <xref linkend="plutosvg"/>, and
      &sdl3;
    </para>

    <bridgehead renderas="sect4">Recommended</bridgehead>
    <para role="recommended">
      <ulink url="&blfs-svn;/multimedia/alsa-lib.html">alsa-lib</ulink>,
      &egl;
      <ulink url="&blfs-svn;/multimedia/gstreamer.html">gstreamer</ulink>,
      <xref linkend="libbacktrace"/>,
      <ulink url="&blfs-svn;/kde/kddockwidgets.html">KDDockWidgets</ulink>,
      <ulink url="&blfs-svn;/multimedia/pulseaudio.html">PulseAudio</ulink>,
      <ulink url="&blfs-svn;/x/qt6.html">Qt-6</ulink>,
      <xref linkend="shaderc"/>,
      <ulink url="&blfs-svn;/multimedia/speex.html">Speex</ulink>,
      <ulink url="&blfs-svn;/x/vulkan-headers.html">Vulkan-Headers</ulink>,
      <ulink url="&blfs-svn;/general/wayland.html">Wayland</ulink>,
      <ulink url="&blfs-svn;/general/wayland-protocols.html">Wayland-Protocols</ulink>, and
      <ulink url="&blfs-svn;/x/x7lib.html">Xorg Libraries</ulink>
    </para>

    <bridgehead renderas="sect4">Optional</bridgehead>
    <para role="optional">
      <ulink url="&blfs-svn;/multimedia/alsa-utils.html">alsa-utils</ulink> and
