  <sect2 role="package">
    <title>Introduction to ksh</title>

    <para>
      The ksh package contains the Korn Shell.
    </para>

    <bridgehead renderas="sect3">Package Information</bridgehead>
    <itemizedlist spacing="compact">
      <listitem>
        <para>
          Download (HTTP): <ulink url="&ksh-download-http;"/>
        </para>
      </listitem>
    </itemizedlist>
   
  </sect2>

  <sect2 role="installation">
    <title>Installation of ksh</title>

    <para>
      Install <application>ksh</application> by executing the following
      commands:
    </para>

<screen><userinput>bin/package make</userinput></screen>

    <para>
      Now as the &root; user:
    </para>

<screen role="root"><userinput>bin/package install /usr</userinput></screen>

  </sect2>

  <sect2>
    <title>Command Explanations</title>

    <para>
      <command>bin/package make -j&lt;N&gt;</command>: You can use this command
      invocation for a parallel build.
    </para>

  </sect2>

