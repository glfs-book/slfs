      <seglistitem>
        <seg>
          hyprcursor-util,
          hyprland-dialog,
          hyprland-donate-screen,
          hyprland-update-screen, and
          hyprwayland-scanner
        </seg>
        <seg>
          libaquamarine,
          libhyprcursor,
          libhyprgraphics,
          libhyprland-quick-style-implplugin,
