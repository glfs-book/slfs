<sect1 id="hyprlib" xreflabel="Hypr Libraries">
  <?dbhtml filename="hyprlib.html"?>

  <title>Hypr Libraries</title>

  <indexterm zone="hyprlib">
    <primary sortas="a-hyprlib">Hypr Libraries</primary>
  </indexterm>

  <sect2 role="package">
    <title>Introduction to Hypr Libraries</title>

    <para>
      The Hypr libraries provide needed utilities for the entire Hypr
      ecosystem. While three of the packages installed in this page are not
      strictly required (hyprtoolkit, hyprland-qt-support, and
      hyprland-guiutils), they are needed for some dialog boxes and this book
      assumes that you have built them.
    </para>

    &abi-break;

    &long-build-time;

    <itemizedlist spacing="compact">
      <listitem>
        <para>
          Download (HTTP): <ulink url="&hyprlib-download-http;"/>
        </para>
      </listitem>
    </itemizedlist>

    <bridgehead renderas="sect3">Hypr Libraries Dependencies</bridgehead>

    <bridgehead renderas="sect4">Required</bridgehead>
    <para role="required">
      <ulink url="&blfs-svn;/x/cairo.html">Cairo</ulink>,
      <ulink url="&blfs-svn;/general/cmake.html">CMake</ulink>,
      &gbm;,
      <ulink url="&blfs-svn;/x/glslang.html">Glslang</ulink>,
      <ulink url="&blfs-svn;/general/libdisplay-info.html">libdisplay-info</ulink>,
      <ulink url="&blfs-svn;/x/libdrm.html">libdrm</ulink>,
      <ulink url="&blfs-svn;/x/x7driver.html#libinput">libinput</ulink>,
      <ulink url="&blfs-svn;/general/libjxl.html">libjxl</ulink>,
      <ulink url="&blfs-svn;/general/libpng.html">libpng</ulink>,
      <ulink url="&blfs-svn;/general/librsvg.html">librsvg</ulink>,
      <ulink url="&blfs-svn;/general/libwebp.html">libwebp</ulink>,
      <xref linkend="libzip"/>,
      &wayland-gl;,
      <ulink url="&blfs-svn;/general/pixman.html">Pixman</ulink>,
      <xref linkend="pugixml"/>,
      <ulink url="&blfs-svn;/x/qt6.html">Qt-6</ulink>,
      <xref linkend="seatd"/>,
      <xref linkend="tomlplusplus"/>,
      <ulink url="&blfs-svn;/general/wayland.html">Wayland</ulink>, and
      <ulink url="&blfs-svn;/general/wayland-protocols.html">Wayland-Protocols</ulink>
    </para>

    <bridgehead renderas="sect4">Recommended</bridgehead>
    <para role="recommended">
      <ulink url="&blfs-svn;/postlfs/profile.html">Bash Shell Startup
      Files</ulink> and
      <ulink url="&blfs-svn;/general/hwdata.html">hwdata</ulink>
    </para>

  </sect2>

  <sect2>
    <title>Downloading Hypr Libraries</title>

    <para>
      First create a list of files to be downloaded:
    </para>

<screen><userinput>cat &gt; hypr-list &lt;&lt; "EOF"
<literal>hyprland-protocols/archive/v&hyprland-protocols-version;/hyprland-protocols-v&hyprland-protocols-version;.tar.gz
hyprutils/archive/v&hyprutils-version;/hyprutils-v&hyprutils-version;.tar.gz
hyprlang/archive/v&hyprlang-version;/hyprlang-v&hyprlang-version;.tar.gz
hyprcursor/archive/v&hyprcursor-version;/hyprcursor-v&hyprcursor-version;.tar.gz
hyprwayland-scanner/archive/v&hyprwayland-scanner-version;/hyprwayland-scanner-v&hyprwayland-scanner-version;.tar.gz
aquamarine/archive/v&aquamarine-version;/aquamarine-v&aquamarine-version;.tar.gz
hyprgraphics/archive/v&hyprgraphics-version;/hyprgraphics-v&hyprgraphics-version;.tar.gz
hyprtoolkit/archive/v&hyprtoolkit-version;/hyprtoolkit-v&hyprtoolkit-version;.tar.gz
hyprland-qt-support/archive/v&hyprland-qt-support-version;/hyprland-qt-support-v&hyprland-qt-support-version;.tar.gz
hyprland-guiutils/archive/v&hyprland-guiutils-version;/hyprland-guiutils-v&hyprland-guiutils-version;.tar.gz</literal>
EOF</userinput></screen>

    <para>
      To download the needed files using
      <ulink url="&blfs-svn;/basicnet/wget.html">Wget</ulink>,
      use the following commands: 
    </para>

<screen><userinput>mkdir hyprlib &amp;&amp;
cd    hyprlib &amp;&amp;
grep -v '^#' ../hypr-list | wget -i- -c \
    -B &hyprlib-download-http;</userinput></screen>

  </sect2>

  <sect2 role="installation">
    <title>Installation of Hypr Libraries</title>

    <para>
      Create <filename>/etc/profile.d/hypr.sh</filename> to ensure QML files
      can be loaded and imported as the &root; user:
    </para>

<screen role="root"><userinput>cat &gt; /etc/profile.d/hypr.sh &lt;&lt; "EOF"
<literal># Begin /etc/profile.d/hypr.sh

pathappend /usr/lib/plugins        QT_PLUGIN_PATH
pathappend $QT6DIR/lib/plugins     QT_PLUGIN_PATH

pathappend /usr/lib/qt6/qml        QML2_IMPORT_PATH
pathappend $QT6DIR/lib/qml         QML2_IMPORT_PATH

# End /etc/profile.d/hypr.sh
EOF</literal></userinput></screen>

    &source-profile;

    &as_root;

    <para>
      Next, start a subshell that will exit on error:
    </para>

<screen><userinput>bash -e</userinput></screen>

    <para>
      Install all the packages by running the following commands:
    </para>

<screen><userinput>for package in $(grep -v '^#' ../hypr-list)
do
package=$(basename "$package")
packagedir=${package%.tar.?z*}
packagedir=$(echo -n "$packagedir" | sed 's/-v\([0-9]\)/-\1/')
echo "Building $packagedir"

  tar -xf $package
  pushd $packagedir

  case $packagedir in
    hyprland-protocols-[0-9]* )
      mkdir build
      cd build
        meson setup --prefix=/usr ..
    ;;<!--

    aquamarine-[0-9]* )

      <literal># If Mesa libGL is installed, force CMake to use it</literal>
      if ! pkgconf libglvnd; then
        sed -i 's/OpenGL::OpenGL/OpenGL::GL/g'   \
          CMakeLists.txt
      fi

      mkdir build
      cd    build
        cmake -D CMAKE_INSTALL_PREFIX=/usr       \
              -D CMAKE_BUILD_TYPE=Release        \
              -D CMAKE_SKIP_INSTALL_RPATH=ON     \
              -G Ninja ..
    ;;-->

    * )
      mkdir build
      cd    build
        cmake -D CMAKE_INSTALL_PREFIX=/usr       \
              -D CMAKE_BUILD_TYPE=Release        \
              -D CMAKE_SKIP_INSTALL_RPATH=ON     \
              -D INSTALL_QML_PREFIX=/lib/qt6/qml \
              -D DISABLE_TESTS=ON                \
              -D BUILD_TESTING=OFF               \
              -W no-dev -G Ninja ..
    ;;
  esac

  ninja
  as_root ninja install
  popd
  rm -rf $packagedir
  as_root /sbin/ldconfig
done</userinput></screen>

    <para>
      Finally, exit the shell that was started earlier:
    </para>

<screen><userinput>exit</userinput></screen>

  </sect2>
  
