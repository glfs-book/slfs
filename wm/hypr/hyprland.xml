  <sect2 role="configuration">
    <title>Configuring Hyprland</title>

    <sect3 id="hyprland-config">
      <title>Config Files</title>
      <para>
        <filename>~/.config/hypr/hyprland.conf</filename>. The default version
        is in <filename class="directory">/usr/share/hypr</filename> and will
        not be used and must be copied to
        <filename class="directory">~/.config/hypr</filename>
      </para>

      <indexterm zone="hyprland hyprland-config">
        <primary sortas="e-AA.config">~/.config/hypr/hyprland.conf</primary>
      </indexterm>

    </sect3>

    <sect3><title>Configuration Information</title>

      <para>
        Create the config file:
      </para>

<screen><userinput>mkdir -pv ~/.config/hypr &amp;&amp;
cp /usr/share/hypr/hyprland.conf ~/.config/hypr</userinput></screen>

      <para>
        Now inspect the file and make any changes to suit your workflow.
      </para>

    </sect3>

  </sect2>

  <sect2 role="content">
    <title>Contents</title>

    <segmentedlist>
      <segtitle>Installed Programs</segtitle>
      <segtitle>Installed Libraries</segtitle>
      <segtitle>Installed Directories</segtitle>

      <seglistitem>
        <seg>
          hyprctl,
          hyprland (link to Hyprland),
          Hyprland,
          hyprpm, and
          start-hyprland
        </seg>
        <seg>
          None
        </seg>
        <seg>
          /usr/include/hyprland, /usr/share/hypr, and
          /usr/share/wayland-sessions
        </seg>
      </seglistitem>
    </segmentedlist>

    <variablelist>
      <bridgehead renderas="sect3">Short Descriptions</bridgehead>
      <?dbfo list-presentation="list"?>
      <?dbhtml list-presentation="table"?>

      <varlistentry id="hyprctl">
        <term><command>hyprctl</command></term>
        <listitem>
          <para>
            retrieves and configures information about the current instance of
            <command>Hyprland</command>
          </para>
          <indexterm zone="hyprland hyprctl">
            <primary sortas="b-hyprctl">hyprctl</primary>
          </indexterm>
        </listitem>
      </varlistentry>

      <varlistentry id="hyprland-link">
        <term><command>hyprland</command></term>
        <listitem>
          <para>
            is a symlink pointing to <command>Hyprland</command>
          </para>
          <indexterm zone="hyprland hyprland-link">
            <primary sortas="b-hyprland-link">hyprland</primary>
          </indexterm>
        </listitem>
      </varlistentry>

      <varlistentry id="Hyprland">
        <term><command>Hyprland</command></term>
        <listitem>
          <para>
            is the Hyprland compositor; running directly will output a warning,
            so run <command>start-hyprland</command> instead
          </para>
          <indexterm zone="hyprland Hyprland">
            <primary sortas="b-Hyprland">Hyprland</primary>
          </indexterm>
        </listitem>
      </varlistentry>

      <varlistentry id="hyprpm">
        <term><command>hyprpm</command></term>
        <listitem>
          <para>
            is the plugin manager for <command>Hyprland</command>
          </para>
          <indexterm zone="hyprland hyprpm">
            <primary sortas="b-hyprpm">hyprpm</primary>
          </indexterm>
        </listitem>
      </varlistentry>

      <varlistentry id="start-hyprland">
        <term><command>start-hyprland</command></term>
        <listitem>
          <para>
            is the recommended way to start Hyprland, which starts a watchdog
            process
          </para>
          <indexterm zone="hyprland start-hyprland">
            <primary sortas="b-start-hyprland">start-hyprland</primary>
          </indexterm>
        </listitem>
      </varlistentry>

    </variablelist>

  </sect2>

