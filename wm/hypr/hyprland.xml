<sect1 id="hyprland" xreflabel="Hyprland-&hyprland-version;">
  <?dbhtml filename="hyprland.html"?>

  <title>Hyprland-&hyprland-version;</title>

  <indexterm zone="hyprland">
    <primary sortas="a-hyprland">Hyprland</primary>
  </indexterm>

  <sect2 role="package">
    <title>Introduction to Hyprland</title>

    <para>
      Hyprland is an independent Wayland compositor aiming to have more
      features than other Wayland compositors and be highly customizable,
      written in C++.
    </para>

    <important><para>
      Be sure to update all the libraries in <xref linkend="hyprlib"/> prior to
      updating this package to prevent configuration failures, and note that
      doing so will break ABI against the present version of Hyprland until you
      rebuild it. In most cases, Hyprland will still be running if the
      libraries have been updated while in the session, however. In any case,
      rebuild/update this package immediately after upgrading <xref
      linkend="hyprlib"/>.
    </para></important>

    &long-build-time;

    <itemizedlist spacing="compact">
      <listitem>
        <para>
          Download (HTTP): <ulink url="&hyprland-download-http;"/>
        </para>
      </listitem>
    </itemizedlist>

    <bridgehead renderas="sect3">Additional Downloads</bridgehead>
    <itemizedlist spacing="compact">
      <listitem>
        <para>
          Required submodule:
          <ulink url="&udis86-sub;"/>
        </para>
      </listitem>
    </itemizedlist>

    <bridgehead renderas="sect3">Hyprland Dependencies</bridgehead>

    <bridgehead renderas="sect4">Required</bridgehead>
    <para role="required">
      <ulink url="&blfs-svn;/x/cairo.html">Cairo</ulink>,
      <ulink url="&blfs-svn;/general/cmake.html">CMake</ulink>,
      <phrase revision="sysv">
      <ulink url="&blfs-svn;/general/elogind.html">elogind</ulink>,
      </phrase>
      &gbm;,
      <xref linkend="glaze"/>,
      <ulink url="&blfs-svn;/general/glib2.html">GLib</ulink>
      (with GObjectIntrospection),
      <ulink url="&blfs-svn;/x/glslang.html">Glslang</ulink>,
      <xref linkend="hyprlib"/>,
      <ulink url="&blfs-svn;/general/libdisplay-info.html">libdisplay-info</ulink>,
      <ulink url="&blfs-svn;/x/libdrm.html">libdrm</ulink>,
      <ulink url="&blfs-svn;/x/x7driver.html#libinput">libinput</ulink>,
      <xref linkend="libliftoff"/>,
      <ulink url="&blfs-svn;/general/libxkbcommon.html">libxkbcommon</ulink>,
      <ulink url="&blfs-svn;/lxqt/muparser.html">muparser</ulink>,
      &wayland-gl;,
      <ulink url="&blfs-svn;/x/pango.html">Pango</ulink> (with Cairo),
      <ulink url="&blfs-svn;/general/pixman.html">Pixman</ulink>,
      <xref linkend="re2"/>,
      <xref linkend="seatd"/>,
      <phrase revision="systemd">
      <ulink url="&blfs-svn;/general/systemd.html">Systemd</ulink>,
      </phrase>
      <xref linkend="tomlplusplus"/>,
      <ulink url="&blfs-svn;/x/vulkan-loader.html">Vulkan-Loader</ulink>,
      <ulink url="&blfs-svn;/general/wayland.html">Wayland</ulink>,
      <ulink url="&blfs-svn;/general/wayland-protocols.html">Wayland-Protocols</ulink>, and
      <ulink url="&blfs-svn;/x/x7lib.html">Xorg Libraries</ulink><footnote><para>
        Xorg Libraries are required because Hyprland requires Xcursor support,
        provided by libXcursor in Xorg Libraries. Even if you disable Xwayland
        support, you will still need Xorg Libraries.
      </para></footnote>
    </para>

    <bridgehead renderas="sect4">Recommended</bridgehead>
    <para role="recommended">
      <ulink url="&blfs-svn;/x/xcb-utilities.html">XCB Utilities</ulink>,
      <xref linkend="xcb-util-errors"/>, and
      <ulink url="&blfs-svn;/x/xwayland.html">Xwayland</ulink>
    </para>

    <bridgehead renderas="sect4">Optional</bridgehead>
    <para role="optional">
      <ulink url="&blfs-svn;/general/cpio.html">cpio</ulink>
      (to build and install plugins)
    </para>

  </sect2>

  <sect2 role="installation">
    <title>Installation of Hyprland</title>

    <para>
      Extract the udis86 submodule in place:
    </para>

<screen><userinput>tar -xf ../udis86-&hypr-udis86-version;.tar.gz &amp;&amp;
mv -T udis86-&hypr-udis86-version; subprojects/udis86</userinput></screen>

    <para>
      Install Hyprland by running the following commands:
    </para>

<screen><userinput>mkdir build &amp;&amp;
cd    build &amp;&amp;

cmake -D CMAKE_INSTALL_PREFIX=/usr   \
      -D CMAKE_BUILD_TYPE=Release    \
      -D CMAKE_SKIP_INSTALL_RPATH=ON \
      -D BUILD_TESTING=OFF           \
      -W no-dev -G Ninja .. &amp;&amp;
ninja</userinput></screen>

    <para>
      Now, as the &root; user:
    </para>

<screen role="root"><userinput>ninja install</userinput></screen>

  </sect2>

