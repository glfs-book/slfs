<sect1 id="tealdeer" xreflabel="tealdeer-&tealdeer-version;">
  <?dbhtml filename="tealdeer.html"?>

  <title>tealdeer-&tealdeer-version;</title>

  <indexterm zone="tealdeer">
    <primary sortas="a-tealdeer">tealdeer</primary>
  </indexterm>

  <sect2 role="package">
    <title>Introduction to tealdeer</title>

    <para>
      The tealdeer package provides a fast
      <command>tldr</command> program which is an alternative to
      <command>man</command>. It aims to be more concise, approachable, and
      simple than what is offered by most man pages.
    </para>

    &build-use-internet;

    <itemizedlist spacing="compact">
      <listitem>
        <para>
          Download: <ulink url="&tealdeer-download;"/>
        </para>
      </listitem>
    </itemizedlist>

    <bridgehead renderas="sect3">tealdeer Dependencies</bridgehead>

    <bridgehead renderas="sect4">Required</bridgehead>
    <para role="required">
      <ulink url="&blfs-svn;/general/rust.html">Rustc</ulink>
    </para>

  </sect2>

  <sect2 role="installation">
    <title>Installation of tealdeer</title>
    <para>
      Install tealdeer by running the following commands:
    </para>

<screen><userinput>cargo build --release</userinput></screen>

    <para>
      To test the results, issue: <command>cargo test --release</command>.
    </para>

    <para>
      Now, as the &root; user:
    </para>

<screen role="root"><userinput>install -vDm755 target/release/tldr -t /usr/bin/</userinput></screen>

    <para>
      Now download the page cache (this will need to be done for every user):
    </para>

<screen><userinput>tldr --update</userinput></screen>

  </sect2>

