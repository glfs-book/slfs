<sect1 id="scdoc" xreflabel="scdoc-&scdoc-version;">
  <?dbhtml filename="scdoc.html"?>

  <title>scdoc-&scdoc-version;</title>

  <indexterm zone="scdoc">
    <primary sortas="a-scdoc">scdoc</primary>
  </indexterm>

  <sect2 role="package">
    <title>Introduction to scdoc</title>

    <para>
      The scdoc package provides a man page
      generator.
    </para>

    <itemizedlist spacing="compact">
      <listitem>
        <para>
          Download (HTTP): <ulink url="&scdoc-download-http;"/>
        </para>
      </listitem>
    </itemizedlist>
   
  </sect2>

  <sect2 role="installation">
    <title>Installation of scdoc</title>

    <para>
      Install scdoc by executing the following
      commands:
    </para>

<screen><userinput>make PREFIX=/usr LDFLAGS="$LDFLAGS"</userinput></screen>

    <para>
      Now as the &root; user:
    </para>

<screen role="root"><userinput>make PREFIX=/usr install</userinput></screen>

  </sect2>

  <sect2 role="commands">
    <title>Command Explanations</title>

    <para>
      <envar>LDFLAGS="$LDFLAGS"</envar>: This ensures that if
      <envar>$LDFLAGS</envar> is set, that the build system respects it.
      Otherwise, it will unset the variable for the build process.
    </para>

  </sect2>

