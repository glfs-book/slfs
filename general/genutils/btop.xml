<sect1 id="btop" xreflabel="BTOP++-&btop-version;">
  <?dbhtml filename="btop.html"?>

  <title>BTOP++-&btop-version;</title>

  <indexterm zone="btop">
    <primary sortas="a-btop">BTOP++</primary>
  </indexterm>

  <sect2 role="package">
    <title>Introduction to BTOP++</title>

    <para>
      The <application>BTOP++</application> package provides a TUI
      <footnote><para>
        Text-based User Interface.
      </para></footnote>
      system monitor, much like <xref linkend="htop"/>. This package, however,
      boasts even further capabilities.
    </para>

    
    <itemizedlist spacing="compact">
      <listitem>
        <para>
          Download (HTTP): <ulink url="&btop-download-http;"/>
        </para>
      </listitem>
    </itemizedlist>

    <bridgehead renderas="sect3">BTOP++ Dependencies</bridgehead>

    <bridgehead renderas="sect4">Optional</bridgehead>
    <para role="optional">
      <ulink url="&arch-pkgs;/extra/x86_64/lowdown/">lowdown</ulink> and
      <ulink url="&arch-pkgs;/extra/x86_64/rocm-smi-lib/">ROCM-SMI-lib</ulink>
    </para>

  </sect2>

  <sect2 role="installation">
    <title>Installation of BTOP++</title>

    <para>
      Install <application>BTOP++</application> by running the following
      commands:
    </para>

<screen><userinput>make</userinput></screen>

    <para>
      Now, as the &root; user:
    </para>

<screen role="root"><userinput>make PREFIX=/usr install</userinput></screen>

  </sect2>
  
