<sect1 id="imv" xreflabel="imv-&imv-version;">
  <?dbhtml filename="imv.html"?>

  <title>imv-&imv-version;</title>

  <indexterm zone="imv">
    <primary sortas="a-imv">imv</primary>
  </indexterm>

  <sect2 role="package">
    <title>Introduction to imv</title>

    <para>
      The imv package provides an image viewer.
    </para>

    <itemizedlist spacing="compact">
      <listitem>
        <para>
          Download (HTTP): <ulink url="&imv-download-http;"/>
        </para>
      </listitem>
    </itemizedlist>

    <bridgehead renderas="sect3">Additional Downloads</bridgehead>
    <itemizedlist spacing="compact">
      <listitem>
        <para>
          Recommended patch:
          <ulink url="https://glfs-book.github.io/slfs/patches/imv/imv-libexecdir.patch"/>
        </para>
      </listitem>
    </itemizedlist>

    <bridgehead renderas="sect3">imv Dependencies</bridgehead>

    <bridgehead renderas="sect4">Required</bridgehead>
    <para role="required">
      Graphical environment (<ulink
      url="&blfs-svn;/x/xorg-server.html">Xorg-Server</ulink> or
      <ulink url="&blfs-svn;/general/wayland.html">Wayland</ulink>),
      <ulink url="&blfs-svn;/general/icu.html">ICU</ulink>,
      <ulink url="&blfs-svn;/general/libxkbcommon.html">libxkbcommon</ulink>, and
      <ulink url="&blfs-svn;/x/pango.html">Pango</ulink> (with Cairo)
    </para>

    <bridgehead renderas="sect4">Recommended</bridgehead>
    <para role="recommended">
      <ulink url="&glfs-website;/shareddeps/glu.html">GLU</ulink>
    </para>

    <bridgehead renderas="sect4">Optional</bridgehead>
    <para role="optional">
      <ulink url="&pymod;asciidoc">asciidoc</ulink>,
      <ulink url="&blfs-svn;/general/libheif.html">libheif</ulink>,
      <ulink url="&blfs-svn;/general/libjpeg.html">libjpeg-turbo</ulink>,
      <ulink url="&blfs-svn;/general/libjxl.html">libjxl</ulink>,
      <ulink url="&blfs-svn;/general/libpng.html">libpng</ulink>,
      <ulink url="&blfs-svn;/general/librsvg.html">librsvg</ulink>,
      <ulink url="&blfs-svn;/general/libtiff.html">libtiff</ulink>,
      <ulink url="&blfs-svn;/general/libwebp.html">libwebp</ulink>,
      <ulink url="&arch-pkgs;/extra/x86_64/libnsbmp/">libnsbmp</ulink>,
      <ulink url="&arch-pkgs;/extra/x86_64/libnsgif/">libnsgif</ulink>, and
      <ulink url="&arch-pkgs;/extra/any/qoi/">qoi</ulink>
    </para>

  </sect2>

  <sect2 role="installation">
    <title>Installation of imv</title>

    <para>
      Apply a patch to move the Wayland and X11 backends to the libexec
      directory:
    </para>

<screen><userinput>patch -Np1 -i ../imv-libexecdir.patch</userinput></screen>

    <para>
      Install imv by running the following commands:
    </para>

<screen><userinput>mkdir build &amp;&amp;
cd    build &amp;&amp;

meson setup ..                  \
      --prefix=/usr             \
      --libexecdir=/usr/libexec \
      --buildtype=release       \
      -D windows=all            \
      -D unicode=icu            \
      -D test=disabled          \
      -D contrib-commands=false &amp;&amp;

ninja</userinput></screen>

    <para>
      Now, as the &root; user:
    </para>

<screen role="root"><userinput>ninja install</userinput></screen>

  </sect2>

  <sect2 role="commands">
    <title>Command Explanations</title>

    &meson-buildtype-release;

    <para>
      <parameter>--libexecdir=/usr/libexec</parameter>: If the recommended
      patch was applied, this parameter moves the Wayland and X11 backends to
      /usr/libexec.
    </para>

    <para>
      <parameter>-D windows=all</parameter>: This parameter builds support for
      Wayland and X11; imv determines which to use at runtime.
    </para>

    <para>
      <parameter>-D unicode=icu</parameter>: This parameter sets ICU as the
      Unicode backend.
    </para>

    <para>
      <parameter>-D tests=disabled</parameter>: This parameter disables tests.
    </para>

    <para>
      <parameter>-D contrib-commands=false</parameter>: This parameter prevents
      the installation of contributed commands. If you wish to install them,
      remove this parameter.
    </para>

  </sect2>

