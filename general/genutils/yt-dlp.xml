<sect1 id="yt-dlp" xreflabel="yt-dlp-&yt-dlp-version;">
  <?dbhtml filename="yt-dlp.html"?>

  <title>yt-dlp-&yt-dlp-version;</title>

  <indexterm zone="yt-dlp">
    <primary sortas="a-yt-dlp">yt-dlp</primary>
  </indexterm>

  <sect2 role="package">
    <title>Introduction to yt-dlp</title>

    <para>
      The yt-dlp package provides a CLI utility to download audio and video
      files from thousands of websites, including YouTube. It can convert
      downloads into other formats using FFmpeg.
    </para>

    <itemizedlist spacing="compact">
      <listitem>
        <para>
          Download (HTTP): <ulink url="&yt-dlp-download-http;"/>
        </para>
      </listitem>
    </itemizedlist>

    <bridgehead renderas="sect3">yt-dlp Dependencies</bridgehead>

    <bridgehead renderas="sect4">Required</bridgehead>
    <para role="required">
      <ulink url="&blfs-svn;/general/zip.html">Zip</ulink>
    </para>

    <bridgehead renderas="sect4">Recommended</bridgehead>
    <para role="recommended">
      <ulink url="&blfs-svn;/basicnet/curl.html">cURL</ulink>,
      <ulink url="&blfs-svn;/multimedia/ffmpeg.html">FFmpeg</ulink>, and
      <ulink url="&blfs-svn;/postlfs/make-ca.html">make-ca</ulink>
    </para>

    <bridgehead renderas="sect4">Optional</bridgehead>
    <para role="optional">
      <ulink url="&blfs-svn;/general/python-modules.html#requests">requests</ulink> and
      <ulink url="&blfs-svn;/general/brotli.html">brotli</ulink>
    </para>

  </sect2>

  <sect2 role="installation">
    <title>Installation of yt-dlp</title>

    <para>
      Install yt-dlp by running the following commands:
    </para>

<screen><userinput>make yt-dlp</userinput></screen>

    <para>
      Now, as the &root; user:
    </para>

<screen role="root"><userinput>install -vDm755 yt-dlp -t /usr/bin/</userinput></screen>

  </sect2>

