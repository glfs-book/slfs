<sect1 id="jstest-sdl" xreflabel="jstest-sdl-&jstest-sdl-minor-version;">
  <?dbhtml filename="jstest-sdl.html"?>

  <title>jstest-sdl-&jstest-sdl-minor-version;</title>

  <indexterm zone="jstest-sdl">
    <primary sortas="a-jstest-sdl">jstest-sdl</primary>
  </indexterm>

  <sect2 role="package">
    <title>Introduction to jstest-sdl</title>

    <para>
      The jstest-sdl package provides a program for
      testing gamepad/joystick inputs, which can help with mapping controllers
      manually as described in <xref linkend="m64plus-components"/>.
    </para>

    <itemizedlist spacing="compact">
      <listitem>
        <para>
          Download (HTTP): <ulink url="&jstest-sdl-download-http;"/>
        </para>
      </listitem>
    </itemizedlist>

    <bridgehead renderas="sect3">jstest-sdl Dependencies</bridgehead>

    <bridgehead renderas="sect4">Required</bridgehead>
    <para role="required">
      &sdl2;
    </para>

  </sect2>

  <sect2 role="installation">
    <title>Installation of jstest-sdl</title>

    <para>
      Install jstest-sdl by running the following
      commands:
    </para>

<screen><userinput>sed -i 's/\-ltinfo//g' Makefile &amp;&amp;
make</userinput></screen>

    <para>
      Now, as the &root; user:
    </para>

<screen role="root"><userinput>install -v -m755 jstest-sdl /usr/bin/</userinput></screen>

  </sect2>

  <sect2 role="commands">
    <title>Command Explanations</title>

    <para>
      <command>sed -i 's/\-ltinfo//g' Makefile</command>: This command avoids
      linking against an Ncurses library that wasn't
      built in LFS.
    </para>

  </sect2>

