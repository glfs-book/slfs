<sect1 id="wgetpaste" xreflabel="wgetpaste-&wgetpaste-version;">
  <?dbhtml filename="wgetpaste.html"?>

  <title>wgetpaste-&wgetpaste-version;</title>

  <indexterm zone="wgetpaste">
    <primary sortas="a-wgetpaste">wgetpaste</primary>
  </indexterm>

  <sect2 role="package">
    <title>Introduction to wgetpaste</title>

    <para>
      The wgetpaste package contains a script which uploads text files to
      pastebin services.
    </para>

    <itemizedlist spacing="compact">
      <listitem>
        <para>
          Download: <ulink url="&wgetpaste-download;"/>
        </para>
      </listitem>
    </itemizedlist>
  </sect2>

  <sect2 role="installation">
    <title>Installation of wgetpaste</title>

    <para>
      The wgetpaste package does not need to be
      compiled and can be directly installed by running the following command
      as the &root; user:
    </para>

<screen role="root"><userinput>install -vDm755 wgetpaste -t /usr/bin/</userinput></screen>

    <para>
      If you want to install the shell completion file for zsh, execute the
      following as the &root; user:
    </para>

<screen role="root"><userinput>install -vDm644 _wgetpaste -t /usr/share/zsh/site-functions/</userinput></screen>

  </sect2>

