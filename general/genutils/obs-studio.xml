      <ulink url="&blfs-svn;/multimedia/alsa-plugins.html">alsa-plugins</ulink>,
      <ulink url="&blfs-svn;/x/cairo.html">Cairo</ulink>,
      <ulink url="&blfs-svn;/general/cmake.html">CMake</ulink>,
      <ulink url="&blfs-svn;/basicnet/curl.html">cURL</ulink>,
      <ulink url="&blfs-svn;/multimedia/ffmpeg.html">FFmpeg</ulink>,
      <ulink url="&blfs-svn;/general/freetype2.html">FreeType2</ulink>,
      <ulink url="&blfs-svn;/general/fontconfig.html">Fontconfig</ulink>,
      <ulink url="&blfs-svn;/general/glib2.html">GLib2</ulink> (with GObject
      Introspection),
      <xref linkend="jansson"/>,
      <ulink url="&blfs-svn;/x/libdrm.html">libdrm</ulink>,
      <ulink url="&blfs-svn;/multimedia/libva.html">libva</ulink>,
      <ulink url="&blfs-svn;/general/libxkbcommon.html">libxkbcommon</ulink>,
      &opengl;,
      <ulink url="&blfs-svn;/general/pciutils.html">pciutils</ulink>,
      <xref linkend="uthash"/>,
      <ulink url="&blfs-svn;/x/vulkan-loader.html">Vulkan-Loader</ulink>,
