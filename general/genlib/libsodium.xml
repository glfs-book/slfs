<sect1 id="libsodium" xreflabel="libsodium-&libsodium-version;">
  <?dbhtml filename="libsodium.html"?>

  <title>libsodium-&libsodium-version;</title>

  <indexterm zone="libsodium">
    <primary sortas="a-libsodium">libsodium</primary>
  </indexterm>

  <sect2 role="package">
    <title>Introduction to libsodium</title>

    <para>
      The libsodium package provides a cryptography library and is API
      compatible with NaCl, its predecessor.
    </para>

    <itemizedlist spacing="compact">
      <listitem>
        <para>
          Download: <ulink url="&libsodium-download;"/>
        </para>
      </listitem>
    </itemizedlist>

  </sect2>

  <sect2 role="installation">
    <title>Installation of libsodium</title>

    <para>
      Install libsodium by running the following commands:
    </para>

<screen><userinput>./configure --prefix=/usr --disable-static &amp;&amp;
make</userinput></screen>

    <para>
      Now, as the &root; user:
    </para>

<screen role="root"><userinput>make install</userinput></screen>

  </sect2>

  <sect2 role="commands">
    <title>Command Explanations</title>

    &static-libraries;

  </sect2>

