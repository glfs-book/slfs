<sect1 id="libzmq" xreflabel="libzmq-&libzmq-version;">
  <?dbhtml filename="libzmq.html"?>

  <title>libzmq-&libzmq-version;</title>

  <indexterm zone="libzmq">
    <primary sortas="a-libzmq">libzmq</primary>
  </indexterm>

  <sect2 role="package">
    <title>Introduction to libzmq</title>

    <para>
      The libzmq, or ZeroMQ/0MQ, package provides a library for extending
      socket interfaces that are common, and provides abstractions for
      messages.
    </para>

    <itemizedlist spacing="compact">
      <listitem>
        <para>
          Download: <ulink url="&libzmq-download;"/>
        </para>
      </listitem>
    </itemizedlist>

    <bridgehead renderas="sect3">libzmq Dependencies</bridgehead>

    <bridgehead renderas="sect4">Recommended</bridgehead>
    <para role="recommended">
      <ulink url="&blfs-svn;/general/libunwind.html">libunwind</ulink>
    </para>

    <bridgehead renderas="sect4">Optional</bridgehead>
    <para role="optional">
      <ulink url="&blfs-svn;/general/asciidoctor.html">asciidoctor</ulink>,
      <ulink url="&blfs-svn;/general/valgrind.html">Valgrind</ulink>, and
      <ulink url="&blfs-svn;/pst/xmlto.html">xmlto</ulink>
    </para>

  </sect2>

  <sect2 role="installation">
    <title>Installation of libzmq</title>

    <para>
      Install libzmq by running the following commands:
    </para>

<screen><userinput>./autogen.sh &amp;&amp;
./configure --prefix=/usr --disable-static &amp;&amp;
make</userinput></screen>

    <para>
      Now, as the &root; user:
    </para>

<screen role="root"><userinput>make install</userinput></screen>

  </sect2>

