<sect1 id="libsrtp" xreflabel="libsrtp-&libsrtp-version;">
  <?dbhtml filename="libsrtp.html"?>

  <title>libsrtp-&libsrtp-version;</title>

  <indexterm zone="libsrtp">
    <primary sortas="a-libsrtp">libsrtp</primary>
  </indexterm>

  <sect2 role="package">
    <title>Introduction to libsrtp</title>

    <para>
      The libsrtp package provides functions for Secure Realtime Transport
      Protocol, or SRTP.
    </para>

    <itemizedlist spacing="compact">
      <listitem>
        <para>
          Download (HTTP): <ulink url="&libsrtp-download-http;"/>
        </para>
      </listitem>
    </itemizedlist>

    <bridgehead renderas="sect3">libsrtp Dependencies</bridgehead>

    <bridgehead renderas="sect4">Recommended</bridgehead>
    <para role="recommended">
      <ulink url="&blfs-svn;/general/nspr.html">NSPR</ulink> and
      <ulink url="&blfs-svn;/postlfs/nss.html">NSS</ulink>
    </para>

    <bridgehead renderas="sect4">Optional</bridgehead>
    <para role="optional">
      <ulink url="&blfs-svn;/general/doxygen.html">doxygen</ulink>
    </para>

  </sect2>

  <sect2 role="installation">
    <title>Installation of libsrtp</title>

    <para>
      Install <application>libsrtp</application> by running the following
      commands:
    </para>

<screen><userinput>mkdir build &amp;&amp;
cd    build &amp;&amp;

meson setup --prefix=/usr                  \
            --buildtype=release            \
            -D crypto-library=nss          \
            -D crypto-library-kdf=disabled \
            .. &amp;&amp;

ninja</userinput></screen>

    <para>
      Now, as the &root; user:
    </para>

<screen role="root"><userinput>ninja install</userinput></screen>

  </sect2>
  
