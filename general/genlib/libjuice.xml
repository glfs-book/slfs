<sect1 id="libjuice" xreflabel="libjuice-&libjuice-version;">
  <?dbhtml filename="libjuice.html"?>

  <title>libjuice-&libjuice-version;</title>

  <indexterm zone="libjuice">
    <primary sortas="a-libjuice">libjuice</primary>
  </indexterm>

  <sect2 role="package">
    <title>Introduction to libjuice</title>

    <para>
      The libjuice package provides a reimplementation of UDP ICE with NAT.
    </para>

    <itemizedlist spacing="compact">
      <listitem>
        <para>
          Download (HTTP): <ulink url="&libjuice-download-http;"/>
        </para>
      </listitem>
    </itemizedlist>

    <bridgehead renderas="sect3">libjuice Dependencies</bridgehead>

    <bridgehead renderas="sect4">Required</bridgehead>
    <para role="required">
      <ulink url="&blfs-svn;/general/cmake.html">CMake</ulink>
    </para>

  </sect2>

  <sect2 role="installation">
    <title>Installation of libjuice</title>

    <para>
      Install libjuice by running the following
      commands:
    </para>

<screen><userinput>mkdir build &amp;&amp;
cd    build &amp;&amp;

cmake -D CMAKE_INSTALL_PREFIX=/usr   \
      -D CMAKE_BUILD_TYPE=Release    \
      -D CMAKE_SKIP_INSTALL_RPATH=ON \
      -G Ninja .. &amp;&amp;

ninja</userinput></screen>

    <para>
      Now, as the &root; user:
    </para>

<screen role="root"><userinput>ninja install</userinput></screen>

  </sect2>

  <sect2 role="commands">
    <title>Command Explanations</title>

    &cmake-skip-install-rpath;

