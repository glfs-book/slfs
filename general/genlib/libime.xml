<sect1 id="libime" xreflabel="libime-&libime-version;">
  <?dbhtml filename="libime.html"?>

  <title>libime-&libime-version;</title>

  <indexterm zone="libime">
    <primary sortas="a-libime">libime</primary>
  </indexterm>

  <sect2 role="package">
    <title>Introduction to libime</title>

    <para>
      The libime package provides a library with support functions for
      implementing generic input methods.
    </para>

    <itemizedlist spacing="compact">
      <listitem>
        <para>
          Download (HTTP): <ulink url="&libime-download-http;"/>
        </para>
      </listitem>
    </itemizedlist>

    <bridgehead renderas="sect3">Additional Downloads</bridgehead>
    <itemizedlist spacing="compact">
      <listitem>
        <para>
          Required submodule:
          <ulink url="https://github.com/kpu/kenlm/archive/&libime-kenlm;.tar.gz"/>
        </para>
      </listitem>
    </itemizedlist>

    <bridgehead renderas="sect3">libime Dependencies</bridgehead>

    <bridgehead renderas="sect4">Required</bridgehead>
    <para role="required">
      <ulink url="&blfs-svn;/general/boost.html">Boost</ulink>,
      <ulink url="&blfs-svn;/general/cmake.html">CMake</ulink>,
      <ulink url="&blfs-svn;/kde/extra-cmake-modules.html">extra-cmake-modules</ulink>,
      and <xref linkend="fcitx5"/>
    </para>

    <bridgehead renderas="sect4">Optional</bridgehead>
    <para role="optional">
      <ulink url="&blfs-svn;/general/doxygen.html">doxygen</ulink> (to build
      the documentation)
    </para>

  </sect2>

  <sect2 role="installation">
    <title>Installation of libime</title>

    <para>
      Unpack the kenlm submodule into the right place:
    </para>

<screen><userinput>tar -xvf ../&libime-kenlm;.tar.gz -C src/libime/core &amp;&amp;
rmdir src/libime/core/kenlm &amp;&amp;
mv src/libime/core/kenlm-&libime-kenlm; src/libime/core/kenlm</userinput></screen>

    <para>
      Install libime by running the following
      commands:
    </para>

<screen><userinput>mkdir build &amp;&amp;
cd    build &amp;&amp;

cmake -D CMAKE_INSTALL_PREFIX=/usr   \
      -D CMAKE_BUILD_TYPE=Release    \
      -D CMAKE_SKIP_INSTALL_RPATH=ON \
      -D BUILD_SHARED_LIBS=ON        \
      -D ENABLE_TEST=OFF             \
      -Wno-dev .. &amp;&amp;

make</userinput></screen>

    <para>
      If you have passed the <option>-D ENABLE_DOC=ON</option> parameter to 
      CMake, build the documentation by executing the following commands:
    </para>

<screen><userinput>make doc</userinput></screen>

    <para>
      Now, as the &root; user:
    </para>

<screen role="root"><userinput>make install</userinput></screen>

    <para>
      If you have built the documentation, install it as the &root; user:
    </para>

<!-- install doesn't support recursive copy and there's no doc install
target... ugh -->
<screen role="root"><userinput>install -v -m755 -d /usr/share/doc/libime-&libime-version; &amp;&amp;
cp -rv doc/html/* /usr/share/doc/libime-&libime-version;</userinput></screen>

  </sect2>

  <sect2 role="commands">
    <title>Command Explanations</title>

    &cmake-skip-install-rpath;

    <para>
      <parameter>-D BUILD_SHARED_LIBS=ON</parameter>: This ensures shared
      libraries are built.
    </para>

    <para>
      <option>-D ENABLE_DOC=ON</option>: Use this switch if you want to
      build the documentation (requires doxygen).
    </para>

  </sect2>

  <sect2 role="content">
    <title>Contents</title>

