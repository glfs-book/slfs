        </seg>
        <seg>
          /usr/include/iniparser and /usr/lib/cmake/iniparser
        </seg>
      </seglistitem>
    </segmentedlist>

    <variablelist>
      <bridgehead renderas="sect3">Short Descriptions</bridgehead>
