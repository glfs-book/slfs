<sect1 id="iniparser" xreflabel="iniparser-&iniparser-version;">
  <?dbhtml filename="iniparser.html"?>

  <title>iniparser-&iniparser-version;</title>

  <indexterm zone="iniparser">
    <primary sortas="a-iniparser">iniparser</primary>
  </indexterm>

  <sect2 role="package">
    <title>Introduction to iniparser</title>

    <para>
      The iniparser package provides a C
      library for parsing <filename class="extension">.ini</filename> files.
    </para>

    <itemizedlist spacing="compact">
      <listitem>
        <para>
          Download: <ulink url="&iniparser-download;"/>
        </para>
      </listitem>
    </itemizedlist>

    <bridgehead renderas="sect3">iniparser Dependencies</bridgehead>

    <bridgehead renderas="sect4">Required</bridgehead>
    <para role="required">
      <ulink url="&blfs-svn;/general/cmake.html">CMake</ulink>
    </para>

    <bridgehead renderas="sect4">Optional</bridgehead>
    <para role="optional">
      <ulink url="&blfs-svn;/general/doxygen.html">doxygen</ulink>
    </para>

  </sect2>

  <sect2 role="installation">
    <title>Installation of iniparser</title>

    <para>
      Install iniparser by running the following
      commands:
    </para>

<screen><userinput>mkdir build &amp;&amp;
cd    build &amp;&amp;

cmake -D CMAKE_INSTALL_PREFIX=/usr \
      -D CMAKE_BUILD_TYPE=Release  \
      -G Ninja .. &amp;&amp;

ninja</userinput></screen>

    <para>
      Now, as the &root; user:
    </para>

<screen role="root"><userinput>ninja install</userinput></screen>

  </sect2>

  <sect2 role="content">
    <title>Contents</title>

