<sect1 id="asio" xreflabel="asio-&asio-version;">
  <?dbhtml filename="asio.html"?>

  <title>asio-&asio-version;</title>

  <indexterm zone="asio">
    <primary sortas="a-asio">asio</primary>
  </indexterm>

  <sect2 role="package">
    <title>Introduction to asio</title>

    <para>
      The asio package provides a C++ library for ASynchronous I/O networking.
    </para>

    <itemizedlist spacing="compact">
      <listitem>
        <para>
          Download (HTTP): <ulink url="&asio-download-http;"/>
        </para>
      </listitem>
    </itemizedlist>

    <bridgehead renderas="sect3">asio Dependencies</bridgehead>

    <bridgehead renderas="sect4">Required</bridgehead>
    <para role="required">
      <ulink url="&blfs-svn;/general/boost.html">boost</ulink>
    </para>

  </sect2>

  <sect2 role="installation">
    <title>Installation of asio</title>

    <para>
      Install asio by running the following
      commands:
    </para>

<screen><userinput>cd asio &amp;&amp;
autoreconf -fi &amp;&amp;
./configure --prefix=/usr &amp;&amp;
make</userinput></screen>

    <para>
      To test the results, issue: <command>make check</command>
    </para>

    <para>
      Now, as the &root; user:
    </para>

<screen role="root"><userinput>make install</userinput></screen>

  </sect2>
  
