<sect1 id="simde" xreflabel="SIMDe-&simde-version;">
  <?dbhtml filename="simde.html"?>

  <title>SIMDe-&simde-version;</title>

  <indexterm zone="simde">
    <primary sortas="a-simde">SIMDe</primary>
  </indexterm>

  <sect2 role="package">
    <title>Introduction to SIMDe</title>

    <para>
      The SIMDe (SIMD Everywhere) package provides a header-only library
      implementing portable SIMD intrinsics for hardware that doesn't support
      them. An example is SSE on ARM, SIMDe can come in and provide those
      extensions on ARM.
    </para>

    <itemizedlist spacing="compact">
      <listitem>
        <para>
          Download: <ulink url="&simde-download;"/>
        </para>
      </listitem>
    </itemizedlist>

  </sect2>

  <sect2 role="installation">
    <title>Installation of SIMDe</title>

    <para>
      Prepare the installation of SIMDe by running the following commands:
    </para>

<screen><userinput>mkdir build &amp;&amp;
cd    build &amp;&amp;

meson setup --prefix=/usr       \
            --buildtype=release \
            -D tests=false      \
            ..</userinput></screen>

    <para>
      Now, as the &root; user:
    </para>

<screen role="root"><userinput>ninja install</userinput></screen>

  </sect2>

