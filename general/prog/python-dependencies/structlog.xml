        and <ulink url='&pydep;hatch-vcs'>hatch_vcs</ulink>
      </para>

    </sect3>

    <sect3 role="installation">
      <title>Installation of structlog</title>

      <para>Build the module:</para>

      &build-wheel;

      <para>
        Now, as the &root; user:
      </para>

<screen role="root"><userinput>&install-wheel; structlog</userinput></screen>

