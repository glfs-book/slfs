    <sect3 role="package">
      <title>Introduction to pycurl Module</title>

      <para>
        The pycurl module offers access to
        cURL in Python
        scripts.
      </para>

      <itemizedlist spacing="compact">
        <listitem>
          <para>
            Download: <ulink url="&pycurl-download;"/>
          </para>
        </listitem>
      </itemizedlist>

      <bridgehead renderas="sect4">pycurl Dependencies</bridgehead>

      <bridgehead renderas="sect5">Required</bridgehead>
      <para role='required'>
        <ulink url='&blfs-svn;/basicnet/curl.html'>cURL</ulink>
      </para>

    </sect3>

    <sect3 role="installation">
      <title>Installation of pycurl</title>

      <para>Build the module:</para>

      &build-wheel;

      <para>
        Now, as the &root; user:
      </para>

<screen role="root"><userinput>&install-wheel; pycurl &amp;&amp;
mv -v /usr/share/doc/pycurl{,-&pycurl-version;}</userinput></screen>

    </sect3>

