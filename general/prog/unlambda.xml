<sect1 id="unlambda" xreflabel="unlambda-&unlambda-version;">
  <?dbhtml filename="unlambda.html"?>

  <title>Unlambda-&unlambda-version;</title>

  <indexterm zone="unlambda">
    <primary sortas="a-unlambda">Unlambda</primary>
  </indexterm>

  <sect2 role="package">
    <title>Introduction to unlambda</title>

    <para>
      The Unlambda package contains an interpreter for the Unlambda programming
      language.
    </para>

    <itemizedlist spacing="compact">
      <listitem>
        <para>
          Download (HTTP): <ulink url="&unlambda-download-http;"/>
        </para>
      </listitem>
    </itemizedlist>

    <bridgehead renderas="sect3">Unlambda Dependencies</bridgehead>

    <bridgehead renderas="sect4">Required</bridgehead>
    <para role="required">
      <ulink url="&blfs-svn;/general/gc.html">GC</ulink>
    </para>

  </sect2>

  <sect2 role="installation">
    <title>Installation of Unlambda</title>

    <para>
      Install Unlambda by executing the following
      commands:
    </para>

<screen><userinput>sed -i '32i #include &lt;stdlib.h&gt;' c/unlambda.c &amp;&amp;
cc -o c/unlambda c/unlambda.c -I/usr/include/gc -lgc</userinput></screen>

    <para>
      Now as the &root; user:
    </para>

<screen role="root"><userinput>install -v -m755 c/unlambda /usr/bin/</userinput></screen>

  </sect2>

  <sect2 role="commands">
    <title>Command Explanations</title>

    <para>
      <command>sed -i '32i #include &lt;stdlib.h&gt;' c/unlambda.c</command>:
      This command fixes the compile with GCC 14 and newer.
    </para>

  </sect2>

