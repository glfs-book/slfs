<sect1 id="wev" xreflabel="wev-&wev-version;">
  <?dbhtml filename="wev.html"?>

  <title>wev-&wev-version;</title>

  <indexterm zone="wev">
    <primary sortas="a-wev">wev</primary>
  </indexterm>

  <sect2 role="package">
    <title>Introduction to wev</title>

    <para>
      The wev package contains a utility to show Wayland events.
    </para>

    <itemizedlist spacing="compact">
      <listitem>
        <para>
          Download: <ulink url="&wev-download;"/>
        </para>
      </listitem>
    </itemizedlist>

    <bridgehead renderas="sect3">wev Dependencies</bridgehead>

    <bridgehead renderas="sect4">Required</bridgehead>
    <para role="required">
      <ulink url="&blfs-svn;/general/libxkbcommon.html">libxkbcommon</ulink>,
      <xref linkend="scdoc"/>,
      <ulink url="&blfs-svn;/general/wayland.html">Wayland</ulink>, and
      <ulink url="&blfs-svn;/general/wayland-protocols.html">Wayland-Protocols</ulink>
    </para>

    <bridgehead renderas="sect4">Optional</bridgehead>
    <para role="required">
      <xref linkend="optional"/>
    </para>

  </sect2>

  <sect2 role="installation">
    <title>Installation of wev</title>

    <para>
      Install wev by executing the following commands:
    </para>

    <screen><userinput>make wev</userinput></screen>

    <para>
      Now as the &root; user:
    </para>

<screen role="root"><userinput>install -vDm755 wev -t /usr/bin/</userinput></screen>

    <para>
      If you installed <xref linkend="scdoc"/>, generate the documentation:
    </para>

    <screen remap="doc"><userinput>make wev.1</userinput></screen>

    <para>
      If you generated the documentation, install it now as the &root; user:
    </para>

<screen role="root"
  remap="doc"><userinput>install -vDm644 wev.1 -t /usr/share/man/man1/</userinput></screen>

  </sect2>

  <sect2 role="content">
    <title>Contents</title>

