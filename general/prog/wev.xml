          <para>
            is a Wayland event tracker
          </para>
          <indexterm zone="wev wev-bin">
            <primary sortas="b-wev-bin">wev</primary>
          </indexterm>
        </listitem>
      </varlistentry>

    </variablelist>

  </sect2>

