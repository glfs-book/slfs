<sect1 id="autoconf-archive" xreflabel="autoconf-archive-&autoconf-archive-version;">
  <?dbhtml filename="autoconf-archive.html"?>

  <title>Autoconf Archive &autoconf-archive-version;</title>

  <indexterm zone="autoconf-archive">
    <primary sortas="a-autoconf-archive">autoconf-archive</primary>
  </indexterm>

  <sect2 role="package">
    <title>Introduction to the Autoconf Archive</title>

    <para>
      The Autoconf Archive contains more than 500 autoconf macros contributed
      to GNU.
    </para>

    <itemizedlist spacing="compact">
      <listitem>
        <para>
          Download (HTTP): <ulink url="&autoconf-archive-download-http;"/>
        </para>
      </listitem>
    </itemizedlist>

  </sect2>

  <sect2 role="installation">
    <title>Installation of autoconf-archive</title>

    <para>
      Install autoconf-archive by executing the following
      commands:
    </para>

<screen><userinput>./configure --prefix=/usr \
--docdir=/usr/share/doc/autoconf-archive-&autoconf-archive-version; &amp;&amp;
make</userinput></screen>

    <para>
      Now as the &root; user:
    </para>

<screen role="root"><userinput>make install</userinput></screen>

  </sect2>

