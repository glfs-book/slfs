<sect1 id="nv-codec-headers" xreflabel="nv-codec-headers-&nv-codec-headers-version;">
  <?dbhtml filename="nv-codec-headers.html"?>


  <title>nv-codec-headers-&nv-codec-headers-version;</title>

  <indexterm zone="nv-codec-headers">
    <primary sortas="a-nv-codec-headers">nv-codec-headers</primary>
  </indexterm>

  <sect2 role="package">
    <title>Introduction to nv-codec-headers</title>

    <para>
      The nv-codec-headers package provides headers for interacting with
      <application>NVIDIA</application> codec APIs.
    </para>

    
    <itemizedlist spacing="compact">
      <listitem>
        <para>
          Download (HTTP): <ulink url="&nv-codec-headers-download-http;"/>
        </para>
      </listitem>
    </itemizedlist>

  </sect2>

  <sect2 role="installation">
    <title>Installation of nv-codec-headers</title>

    <para>
      Install <application>nv-codec-headers</application> by running the following
      command as the &root; user:
    </para>

<screen role="root"><userinput>make PREFIX=/usr install</userinput></screen>

    <para>
      If you are doing multilib, make a symlink for the
      <application>pkgconf</application> file as the &root; user:
    </para>

<screen role="root"><userinput>ln -sfv /usr/lib{,32}/pkgconfig/ffnvcodec.pc</userinput></screen>

  </sect2>
  
  <sect2 role="content">
    <title>Contents</title>

