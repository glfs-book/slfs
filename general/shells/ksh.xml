<sect1 id="ksh" xreflabel="ksh-&ksh-version;">
  <?dbhtml filename="ksh.html"?>

  <title>ksh-&ksh-version;</title>

  <indexterm zone="ksh">
    <primary sortas="a-ksh">ksh</primary>
  </indexterm>

  <sect2 role="package">
    <title>Introduction to ksh</title>

    <para>
      The ksh package contains the Korn Shell.
    </para>

    
    <itemizedlist spacing="compact">
      <listitem>
        <para>
          Download (HTTP): <ulink url="&ksh-download-http;"/>
        </para>
      </listitem>
    </itemizedlist>
   
  </sect2>

  <sect2 role="installation">
    <title>Installation of ksh</title>

    <para>
      Install <application>ksh</application> by executing the following
      commands:
    </para>

<screen><userinput>bin/package make</userinput></screen>

    <para>
      Now as the &root; user:
    </para>

<screen role="root"><userinput>bin/package install /usr</userinput></screen>

  </sect2>

  <sect2 role="configuration">
    <title>Configuring heirloom-sh</title>

    <sect3><title>Configuration Information</title>

      <para>
        As the &root; user, update <filename>/etc/shells</filename> to include
        the Korn shell program names:
      </para>

<screen role="root"><userinput>cat &gt;&gt; /etc/shells &lt;&lt; "EOF"
<literal>/usr/bin/ksh</literal>
EOF</userinput></screen>

    </sect3>

  </sect2>

  <sect2 role="content">
    <title>Contents</title>

    <segmentedlist>
      <segtitle>Installed Programs</segtitle>
      <segtitle>Installed Libraries</segtitle>
      <segtitle>Installed Directories</segtitle>

      <seglistitem>
        <seg>
          ksh and shcomp
        </seg>
        <seg>
          libast.so, libcmd.so, libdll.so, and libshell.so
        </seg>
        <seg>
          /usr/include/ast and /usr/share/fun
        </seg>
      </seglistitem>
    </segmentedlist>

    <variablelist>
      <bridgehead renderas="sect3">Short Descriptions</bridgehead>
      <?dbfo list-presentation="list"?>
      <?dbhtml list-presentation="table"?>

      <varlistentry id="ksh-bin">
        <term><command>ksh</command></term>
        <listitem>
          <para>
            is the Korn Shell
          </para>
          <indexterm zone="ksh ksh-bin">
            <primary sortas="b-ksh-bin">ksh</primary>
          </indexterm>
        </listitem>
      </varlistentry>

      <varlistentry id="shcomp">
        <term><command>shcomp</command></term>
        <listitem>
          <para>
            compiles a shell script
          </para>
          <indexterm zone="ksh shcomp">
            <primary sortas="b-shcomp">shcomp</primary>
          </indexterm>
        </listitem>
      </varlistentry>

      <varlistentry id="libast">
        <term><filename class="libraryfile">libast.so</filename></term>
        <listitem>
          <para>
            is the AT&amp;T Software Technology library
          </para>
          <indexterm zone="ksh libast">
            <primary sortas="c-libast">libast.so</primary>
          </indexterm>
        </listitem>
      </varlistentry>

      <varlistentry id="libcmd">
        <term><filename class="libraryfile">libcmd.so</filename></term>
        <listitem>
          <para>
            contains <command>ksh</command> loadable builtins
          </para>
          <indexterm zone="ksh libcmd">
            <primary sortas="c-libcmd">libcmd.so</primary>
          </indexterm>
        </listitem>
      </varlistentry>

      <varlistentry id="libdll">
        <term><filename class="libraryfile">libdll.so</filename></term>
        <listitem>
          <para>
            contains wrappers around dlopen() and similar functions
          </para>
          <indexterm zone="ksh libdll">
            <primary sortas="c-libdll">libdll.so</primary>
          </indexterm>
        </listitem>
      </varlistentry>

      <varlistentry id="libshell">
        <term><filename class="libraryfile">libshell.so</filename></term>
        <listitem>
          <para>
            contains the <command>ksh</command> library interface
          </para>
          <indexterm zone="ksh libshell">
            <primary sortas="c-libshell">libshell.so</primary>
          </indexterm>
        </listitem>
      </varlistentry>

    </variablelist>

  </sect2>  

</sect1>
