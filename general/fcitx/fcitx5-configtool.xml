<sect1 id="fcitx5-configtool" xreflabel="Fcitx5-configtool-&fcitx5-configtool-version;">
  <?dbhtml filename="fcitx5-configtool.html"?>

  <title>Fcitx5-configtool-&fcitx5-configtool-version;</title>

  <indexterm zone="fcitx5-configtool">
    <primary sortas="a-fcitx5-configtool">Fcitx5-configtool</primary>
  </indexterm>

  <sect2 role="package">
    <title>Introduction to Fcitx5-configtool</title>

    <para>
      The Fcitx5-configtool package provides a user-friendly configuration
      interface for Fcitx.
    </para>

    <itemizedlist spacing="compact">
      <listitem>
        <para>
          Download (HTTP): <ulink url="&fcitx5-configtool-download-http;"/>
        </para>
      </listitem>
    </itemizedlist>

    <bridgehead renderas="sect3">Fcitx5-configtool Dependencies</bridgehead>

    <bridgehead renderas="sect4">Required</bridgehead>
    <para role="required">
      <ulink url="&blfs-svn;/general/cmake.html">CMake</ulink>,
      <ulink url="&blfs-svn;/kde/extra-cmake-modules.html">extra-cmake-modules</ulink>,
      <ulink url="&blfs-svn;/kde/frameworks6.html">KF6</ulink>,
      <ulink url="&blfs-svn;/x/xkeyboard-config.html">XKeyboardConfig</ulink>,
      <ulink url="&blfs-svn;/general/iso-codes.html">ISO Codes</ulink>,
      <xref linkend="fcitx5"/>, and
      <xref linkend="fcitx5-qt"/>
    </para>

  </sect2>

  <sect2 role="installation">
    <title>Installation of Fcitx5-configtool</title>

    <para>
      Install <application>Fcitx5-configtool</application> by running the following
      commands:
    </para>

<screen><userinput>mkdir build &amp;&amp;
cd    build &amp;&amp;

cmake -D CMAKE_INSTALL_PREFIX=/usr   \
      -D CMAKE_BUILD_TYPE=Release    \
      -D CMAKE_SKIP_INSTALL_RPATH=ON \
      -D ENABLE_KCM=OFF              \
      -Wno-dev .. &amp;&amp;

make</userinput></screen>

    <para>
      Now, as the &root; user:
    </para>

<screen role="root"><userinput>make install</userinput></screen>

  </sect2>

  <sect2 role="commands">
    <title>Command Explanations</title>

    <xi:include xmlns:xi="http://www.w3.org/2001/XInclude"
      href="../../xincludes/cmake-skip-install-rpath.xml"/>

    <para>
      <parameter>-D ENABLE_KCM=OFF</parameter>: This switch disables building
      KDE Plasma integration for Fcitx5-configtool.
    </para>

  </sect2>

  <sect2 role="content">
    <title>Contents</title>

    <segmentedlist>
      <segtitle>Installed Programs</segtitle>
      <segtitle>Installed Libraries</segtitle>
      <segtitle>Installed Directories</segtitle>

      <seglistitem>
        <seg>
          fcitx5-config-qt, fcitx5-migrator, and kbd-layout-viewer5 
        </seg>
        <seg>
          libFcitx5Migrator
        </seg>
        <seg>
          None
        </seg>
      </seglistitem>
    </segmentedlist>

    <variablelist>
      <bridgehead renderas="sect3">Short Descriptions</bridgehead>
      <?dbfo list-presentation="list"?>
      <?dbhtml list-presentation="table"?>

      <varlistentry id="fcitx5-config-qt">
        <term><command>fcitx5-config-qt</command></term>
        <listitem>
          <para>
            is the Fcitx configuration tool
          </para>
          <indexterm zone="fcitx5-configtool fcitx5-config-qt">
            <primary sortas="b-fcitx5-config-qt">fcitx5-config-qt</primary>
          </indexterm>
        </listitem>
      </varlistentry>

      <varlistentry id="fcitx5-migrator">
        <term><command>fcitx5-migrator</command></term>
        <listitem>
          <para>
            is a tool to migrate user data from Fcitx 4 to Fcitx 5
          </para>
          <indexterm zone="fcitx5-configtool fcitx5-migrator">
            <primary sortas="b-fcitx5-migrator">fcitx5-migrator</primary>
          </indexterm>
        </listitem>
      </varlistentry>

      <varlistentry id="kbd-layout-viewer5">
        <term><command>kbd-layout-viewer5</command></term>
        <listitem>
          <para>
            is the Fcitx keyboard layout viewer
          </para>
          <indexterm zone="fcitx5-configtool kbd-layout-viewer5">
            <primary sortas="b-kbd-layout-viewer5">kbd-layout-viewer5</primary>
          </indexterm>
        </listitem>
      </varlistentry>

      <varlistentry id="libFcitx5Migrator">
        <term><filename class="libraryfile">libFcitx5Migrator</filename></term>
        <listitem>
          <para>
            contains the routines for migrating from Fcitx 4 to Fcitx 5
          </para>
          <indexterm zone="fcitx5-configtool libFcitx5Migrator">
            <primary sortas="c-libFcitx5Migrator">libFcitx5Migrator</primary>
          </indexterm>
        </listitem>
      </varlistentry>

    </variablelist>

  </sect2>

