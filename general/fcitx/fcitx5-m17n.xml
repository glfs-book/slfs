  <?dbhtml filename="fcitx5-m17n.html"?>

  <title>Fcitx5-m17n-&fcitx5-m17n-version;</title>

  <indexterm zone="fcitx5-m17n">
    <primary sortas="a-fcitx5-m17n">Fcitx5-m17n</primary>
  </indexterm>

  <sect2 role="package">
    <title>Introduction to Fcitx5-m17n</title>

    <para>
      The Fcitx5-m17n package provides a wrapper around the m17n engine
      for Fcitx.
    </para>

    <itemizedlist spacing="compact">
      <listitem>
        <para>
          Download (HTTP): <ulink url="&fcitx5-m17n-download-http;"/>
        </para>
      </listitem>
    </itemizedlist>

    <bridgehead renderas="sect3">Fcitx5-m17n Dependencies</bridgehead>

    <bridgehead renderas="sect4">Required</bridgehead>
    <para role="required">
      <ulink url="&blfs-svn;/general/cmake.html">CMake</ulink>,
      <ulink url="&blfs-svn;/kde/extra-cmake-modules.html">extra-cmake-modules</ulink>,
      <xref linkend="fcitx5"/>, and <xref linkend="m17n"/>
    </para>

  </sect2>

  <sect2 role="installation">
    <title>Installation of Fcitx5-m17n</title>

    <para>
      Install <application>Fcitx5-m17n</application> by running the following
      commands:
    </para>

<screen><userinput>mkdir build &amp;&amp;
cd    build &amp;&amp;

cmake -D CMAKE_INSTALL_PREFIX=/usr   \
      -D CMAKE_BUILD_TYPE=Release    \
      -D CMAKE_SKIP_INSTALL_RPATH=ON \
      -D ENABLE_TEST=OFF             \
      -Wno-dev .. &amp;&amp;

make</userinput></screen>

    <para>
      Now, as the &root; user:
    </para>

<screen role="root"><userinput>make install</userinput></screen>

  </sect2>

