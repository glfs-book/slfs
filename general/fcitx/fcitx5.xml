<sect1 id="fcitx5" xreflabel="Fcitx-&fcitx5-version;">
  <?dbhtml filename="fcitx5.html"?>

  <title>Fcitx-&fcitx5-version;</title>

  <indexterm zone="fcitx5">
    <primary sortas="a-fcitx5">Fcitx</primary>
  </indexterm>

  <sect2 role="package">
    <title>Introduction to Fcitx</title>

    <para>
      The Fcitx package provides an extensible input method framework.
    </para>

    <itemizedlist spacing="compact">
      <listitem>
        <para>
          Download (HTTP): <ulink url="&fcitx5-download-http;"/>
        </para>
      </listitem>
    </itemizedlist>

    <bridgehead renderas="sect3">Fcitx Dependencies</bridgehead>

    <bridgehead renderas="sect4">Required</bridgehead>
    <para role="required">
      <ulink url="&blfs-svn;/general/cmake.html">CMake</ulink>,
      <ulink url="&blfs-svn;/kde/extra-cmake-modules.html">extra-cmake-modules</ulink>,
      <ulink url="&blfs-svn;/x/libxcb.html">libxcb</ulink>,
      <ulink url="&blfs-svn;/general/json-c.html">JSON-C</ulink>,
      <ulink url="&blfs-svn;/general/dbus.html">dbus</ulink>,
      <ulink url="&blfs-svn;/general/fmt.html">fmt</ulink>,
      <xref linkend="xcb-imdkit"/>
    </para>

    <bridgehead renderas="sect4">Recommended</bridgehead>
    <para role="recommended">
      <xref linkend="cldr-emoji-annotation"/>,
      <ulink url="&blfs-svn;/general/enchant.html">enchant</ulink>
    </para>

    <bridgehead renderas="sect4">Optional</bridgehead>
    <para role="optional">
      <ulink url="&blfs-svn;/general/wayland.html">Wayland</ulink> (TODO figure
      out if this is an exclusive Wayland/X11 switch, if not promote to
      Recommended),
      <ulink url="&blfs-svn;/general/doxygen.html">doxygen</ulink> (to build
      the documentation)
    </para>

  </sect2>

  <sect2 role="installation">
    <title>Installation of Fcitx</title>

    <para>
      Install <application>Fcitx</application> by running the following
      commands:
    </para>

<screen><userinput>mkdir build &amp;&amp;
cd    build &amp;&amp;

cmake -D CMAKE_INSTALL_PREFIX=/usr   \
      -D CMAKE_BUILD_TYPE=Release    \
      -D CMAKE_SKIP_INSTALL_RPATH=ON \
      -D ENABLE_TESTING_ADDONS=OFF \
      -D ENABLE_TEST=OFF \
      -Wno-dev .. &amp;&amp;

make</userinput></screen>

    <para>
      If you have passed the ENABLE_DOC parameter to CMake, build the 
      documentation by executing the following commands:
    </para>

<screen><userinput>make doc</userinput></screen>

    <para>
      Now, as the &root; user:
    </para>

<screen role="root"><userinput>make install</userinput></screen>

    <para>
      If you have built the documentation, install it as the &root; user:
    </para>

<!-- install doesn't support recursive copy and there's no doc install
target... ugh -->
<screen role="root"><userinput>install -v -m755 -d /usr/share/doc/fcitx5-&fcitx5-version; &amp;&amp;
cp -rv doc/html/* /usr/share/doc/fcitx5-&fcitx5-version;</userinput></screen>

  </sect2>

  <sect2 role="commands">
    <title>Command Explanations</title>

    <xi:include xmlns:xi="http://www.w3.org/2001/XInclude"
      href="../../xincludes/cmake-skip-install-rpath.xml"/>

    <para>
      <parameter>-D ENABLE_DOC=ON</parameter>: Use this switch if you want to
      build the documentation (requires <application>doxygen</application>).
    </para>

  </sect2>

