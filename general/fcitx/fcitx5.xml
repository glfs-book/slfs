      <varlistentry id="comp-spell-dict">
        <term><command>comp-spell-dict</command></term>
        <listitem>
          <para>
            compiles a spell dictionary for the spell plugin
          </para>
          <indexterm zone="fcitx5 comp-spell-dict">
            <primary sortas="b-comp-spell-dict">comp-spell-dict</primary>
          </indexterm>
        </listitem>
      </varlistentry>

      <varlistentry id="fcitx5-bin">
        <term><command>fcitx5</command></term>
        <listitem>
          <para>
            is the Fcitx server
          </para>
          <indexterm zone="fcitx5 fcitx5-bin">
            <primary sortas="b-fcitx5-bin">fcitx5</primary>
