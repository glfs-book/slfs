<sect1 id="fcitx5-qt" xreflabel="Fcitx5-Qt-&fcitx5-qt-version;">
  <?dbhtml filename="fcitx5-qt.html"?>

  <title>Fcitx5-Qt-&fcitx5-qt-version;</title>

  <indexterm zone="fcitx5-qt">
    <primary sortas="a-fcitx5-qt">Fcitx5-Qt</primary>
  </indexterm>

  <sect2 role="package">
    <title>Introduction to Fcitx5-Qt</title>

    <para>
      The Fcitx5-Qt package provides a Qt frontend for Fcitx.
    </para>

    <itemizedlist spacing="compact">
      <listitem>
        <para>
          Download (HTTP): <ulink url="&fcitx5-qt-download-http;"/>
        </para>
      </listitem>
    </itemizedlist>

    <bridgehead renderas="sect3">Fcitx5-Qt Dependencies</bridgehead>

    <bridgehead renderas="sect4">Required</bridgehead>
    <para role="required">
      <ulink url="&blfs-svn;/general/cmake.html">CMake</ulink>,
      <ulink url="&blfs-svn;/kde/extra-cmake-modules.html">extra-cmake-modules</ulink>,
      <ulink url="&blfs-svn;/x/libxcb.html">libxcb</ulink>,
      <ulink url="&blfs-svn;/general/libxkbcommon.html">libxkbcommon</ulink>,
      <ulink url="&blfs-svn;/x/qt6.html">Qt6</ulink>,
      <xref linkend="fcitx5"/>
    </para>

  </sect2>

  <sect2 role="installation">
    <title>Installation of Fcitx5-Qt</title>

    <para>
      Install <application>Fcitx5-Qt</application> by running the following
      commands:
    </para>

<screen><userinput>mkdir build &amp;&amp;
cd    build &amp;&amp;

cmake -D CMAKE_INSTALL_PREFIX=/usr   \
      -D CMAKE_BUILD_TYPE=Release    \
      -D CMAKE_SKIP_INSTALL_RPATH=ON \
      -D ENABLE_QT4=OFF \
      -D ENABLE_QT5=OFF \
      -D ENABLE_QT6=ON \
      -Wno-dev .. &amp;&amp;

make</userinput></screen>

    <para>
      Now, as the &root; user:
    </para>

<screen role="root"><userinput>make install</userinput></screen>

  </sect2>

