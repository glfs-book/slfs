<sect1 id="libxp" xreflabel="libXp-&libxp-version;">
  <?dbhtml filename="libxp.html"?>

  <title>libXp-&libxp-version;</title>

  <indexterm zone="libxp">
    <primary sortas="a-libxp">libXp</primary>
  </indexterm>

  <sect2 role="package">
    <title>Introduction to libXp</title>

    <para>
      The libXp package contains a library implementing the X Print Protocol.
    </para>

    
    <itemizedlist spacing="compact">
      <listitem>
        <para>
          Download (HTTP): <ulink url="&libxp-download-http;"/>
        </para>
      </listitem>
    </itemizedlist>

  <bridgehead renderas="sect3">libXp Dependencies</bridgehead>

  <bridgehead renderas="sect4">Required</bridgehead>
  <para role="required">
    <xref linkend="printproto"/> and
    <ulink url="&blfs-svn;/x/x7lib.html">Xorg Libraries</ulink>
  </para>
   
  </sect2>

  <sect2 role="installation">
    <title>Installation of libXp</title>

    <para>
      Install <application>libXp</application> by executing the following
      commands:
    </para>

<screen><userinput>./configure $XORG_CONFIG --docdir=$XORG_PREFIX/share/doc/libXp-&libxp-version; &amp;&amp;
make</userinput></screen>

    <para>
      Now as the &root; user:
    </para>

<screen role="root"><userinput>make install</userinput></screen>

  </sect2>

