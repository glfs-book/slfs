<!ENTITY logind-nocomma
         "<phrase revision='sysv'><ulink
          url='&blfs-svn;/general/elogind.html'>elogind</ulink></phrase>
          <phrase revision='systemd'><ulink
          url='&blfs-svn;/general/systemd.html'>Systemd</ulink></phrase>">

<!ENTITY logind
