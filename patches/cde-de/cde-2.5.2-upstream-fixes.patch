-mpool_filter(MPOOL *mp,
-             void (*pgin) __P((void *, pgno_t, void *)),
-             void (*pgout) __P((void *, pgno_t, void *)),
-             void *pgcookie)
-{
-	mp->pgin = pgin;
-	mp->pgout = pgout;
-	mp->pgcookie = pgcookie;
-}
-	
-/*
- * MPOOL_NEW -- get a new page
