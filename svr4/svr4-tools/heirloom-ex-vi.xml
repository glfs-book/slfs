<sect1 id="heirloom-ex-vi" xreflabel="heirloom-ex-vi-&heirloom-ex-vi-minor-version;">
  <?dbhtml filename="heirloom-ex-vi.html"?>


  <title>heirloom-ex-vi-&heirloom-ex-vi-minor-version;</title>

  <indexterm zone="heirloom-ex-vi">
    <primary sortas="a-heirloom-ex-vi">heirloom-ex-vi</primary>
  </indexterm>

  <sect2 role="package">
    <title>Introduction to heirloom-ex-vi</title>

    <para>
      The heirloom-ex-vi package, also known as
      <quote>The Traditional Vi</quote>, is a portable version of 2.11BSD/SVR4
      vi.
    </para>

    <itemizedlist spacing="compact">
      <listitem>
        <para>
          Download: <ulink url="&heirloom-ex-vi-download;"/>
        </para>
      </listitem>
    </itemizedlist>

    <bridgehead renderas="sect3">Additional Downloads</bridgehead>
    <itemizedlist spacing="compact">
      <listitem>
        <para>
          Required patch:
          <ulink url="&dl-root;/heirloom-ex-vi/heirloom-ex-vi-&heirloom-ex-vi-minor-version;-paths.patch"/>
        </para>
      </listitem>
    </itemizedlist>

    <bridgehead renderas="sect3">heirloom-ex-vi Dependencies</bridgehead>

    <bridgehead renderas="sect4">Optional</bridgehead>
    <para role="optional">
      <ulink url="&blfs-svn;/x/installing.html">The X Window System</ulink>
      (to use wvi)
    </para>

  </sect2>

  <sect2 role="installation">
    <title>Installation of heirloom-ex-vi</title>

    <para>
      Apply a patch to make the installation paths conform with the others in
      this category:
    </para>

<screen><userinput>patch -Np1 -i ../heirloom-ex-vi-&heirloom-ex-vi-minor-version;-paths.patch</userinput></screen>

    <para>
      Install heirloom-ex-vi by running the following
      command:
    </para>

<screen><userinput>./configure &amp;&amp;
CC="cc -std=gnu17" make</userinput></screen>

    <para>
      Now, as the &root; user:
    </para>

<screen role="root"><userinput>make install</userinput></screen>

  </sect2>

  <sect2 role="configuration">
    <title>Configuring heirloom-ex-vi</title>

    <sect3 id="heirloom-ex-vi-config">
      <title>Config Files</title>
      <para>
        <filename>~/.exrc</filename>
      </para>

      <indexterm zone="heirloom-ex-vi heirloom-ex-vi-config">
        <primary sortas="e-AA.exrc">~/.exrc</primary>
      </indexterm>

    </sect3>

    <sect3><title>Configuration Information</title>

      <para>
        The above file can be used to configure the editor. The defaults are
        fine, but the configuration file gets ignored if anyone except the user
        executing vi has the ability to write to it. Make sure the file's octal
        permission value is <computeroutput>644</computeroutput> or similar in
        case you want to use it.
      </para>

    </sect3>

  </sect2>

  <sect2 role="content">
    <title>Contents</title>

    <segmentedlist>
      <segtitle>Installed Programs</segtitle>
      <segtitle>Installed Libraries</segtitle>
      <segtitle>Installed Directories</segtitle>

      <seglistitem>
        <seg>
          edit (link to ex), ex, expreserve, exrecover, vedit (link to ex),
          vi (link to ex), view (link to ex), and wvi
        </seg>
        <seg>
          None
        </seg>
        <seg>
          /var/preserve
        </seg>
      </seglistitem>
    </segmentedlist>

    <variablelist>
      <bridgehead renderas="sect3">Short Descriptions</bridgehead>
      <?dbfo list-presentation="list"?>
      <?dbhtml list-presentation="table"?>

      <varlistentry id="edit">
        <term><command>edit</command></term>
        <listitem>
          <para>
            is a symlink pointing to <command>ex</command>
          </para>
          <indexterm zone="heirloom-ex-vi edit">
            <primary sortas="b-edit">edit</primary>
          </indexterm>
        </listitem>
      </varlistentry>

      <varlistentry id="ex">
        <term><command>ex</command></term>
        <listitem>
          <para>
            is the text editor
          </para>
          <indexterm zone="heirloom-ex-vi ex">
            <primary sortas="b-ex">ex</primary>
          </indexterm>
        </listitem>
      </varlistentry>

      <varlistentry id="expreserve">
        <term><command>expreserve</command></term>
        <listitem>
          <para>
            preserves files into <filename>/var/preserve</filename>
          </para>
          <indexterm zone="heirloom-ex-vi expreserve">
            <primary sortas="b-expreserve">expreserve</primary>
          </indexterm>
        </listitem>
      </varlistentry>

      <varlistentry id="exrecover">
        <term><command>exrecover</command></term>
        <listitem>
          <para>
            recovers files from <filename>/var/preserve</filename>
          </para>
          <indexterm zone="heirloom-ex-vi exrecover">
            <primary sortas="b-exrecover">exrecover</primary>
          </indexterm>
        </listitem>
      </varlistentry>

      <varlistentry id="vedit">
        <term><command>vedit</command></term>
        <listitem>
          <para>
            is a symlink pointing to <command>ex</command>
          </para>
          <indexterm zone="heirloom-ex-vi vedit">
            <primary sortas="b-vedit">vedit</primary>
          </indexterm>
        </listitem>
      </varlistentry>

      <varlistentry id="vi">
        <term><command>vi</command></term>
        <listitem>
          <para>
            is a symlink pointing to <command>ex</command>
          </para>
          <indexterm zone="heirloom-ex-vi vi">
            <primary sortas="b-vi">vi</primary>
          </indexterm>
        </listitem>
      </varlistentry>

      <varlistentry id="view">
        <term><command>view</command></term>
        <listitem>
          <para>
            is a symlink pointing to <command>ex</command>
          </para>
          <indexterm zone="heirloom-ex-vi view">
            <primary sortas="b-view">view</primary>
          </indexterm>
        </listitem>
      </varlistentry>

      <varlistentry id="wvi">
        <term><command>wvi</command></term>
        <listitem>
          <para>
            is a script that opens <command>vi</command> in a
            separate xterm
          </para>
          <indexterm zone="heirloom-ex-vi wvi">
            <primary sortas="b-wvi">wvi</primary>
          </indexterm>
        </listitem>
      </varlistentry>

    </variablelist>

  </sect2>

</sect1>
