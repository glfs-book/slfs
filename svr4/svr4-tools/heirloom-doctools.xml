<sect1 id="heirloom-doctools" xreflabel="heirloom-doctools-&heirloom-doctools-minor-version;">
  <?dbhtml filename="heirloom-doctools.html"?>


  <title>heirloom-doctools-&heirloom-doctools-minor-version;</title>

  <indexterm zone="heirloom-doctools">
    <primary sortas="a-heirloom-doctools">heirloom-doctools</primary>
  </indexterm>

  <sect2 role="package">
    <title>Introduction to heirloom-doctools</title>

    <para>
      The <application>heirloom-doctools</application> package provides
      <application>troff</application>, <application>nroff</application>, and
      other related tools. Those tools are enhanced versions of the tools
      released as a part of OpenSolaris, which are themselves variants of
      ditroff, which are themselves descendants of the original UNIX troff.
    </para>

    
    <itemizedlist spacing="compact">
      <listitem>
        <para>
          Download (HTTP): <ulink url="&heirloom-doctools-download-http;"/>
        </para>
      </listitem>
    </itemizedlist>
   
    <bridgehead renderas="sect3">heirloom-doctools Dependencies</bridgehead>

    <bridgehead renderas="sect4">Required</bridgehead>
    <para role="required">
      &unzip;
      (to unpack the distribution),
      <xref linkend="heirloom-ng"/>, and
      <xref linkend="heirloom-devtools"/>
    </para>

  </sect2>

  <sect2 role="installation">
    <title>Installation of heirloom-doctools</title>

    <para>
      Install <application>heirloom-doctools</application> by running the following
      command:
    </para>

<screen><userinput>./configure &amp;&amp;
make PREFIX=/usr MANDIR=/usr/share/man/5man \
YACC=/usr/ccs/bin/yacc</userinput></screen>

    <para>
      Now, as the &root; user:
    </para>

<screen role="root"><userinput>make PREFIX=/usr MANDIR=/usr/share/man/5man \
install</userinput></screen>

  </sect2>

  <sect2 role="content">
    <title>Contents</title>

    <segmentedlist>
      <segtitle>Installed Programs</segtitle>
      <segtitle>Installed Libraries</segtitle>
      <segtitle>Installed Directories</segtitle>

      <seglistitem>
        <seg>
          addbib, checkeq, checknr, col, dhtml, dpost, eqn, grap, hunt, 
          indxbib, inv, lookbib, mkey, neqn, nroff, otf_info, pic, picpack, pm, 
          ptx, refer, roffbib, runinv, soelim, sortbib, ta, tbl, troff, 
          vfontedpr, and vgrind
        </seg>
        <seg>
          None
        </seg>
        <seg>
          /usr/pub, /usr/ucblib/doctools, and /usr/ucblib/reftools
        </seg>
      </seglistitem>
    </segmentedlist>

    <variablelist>
      <bridgehead renderas="sect3">Short Descriptions</bridgehead>
      <?dbfo list-presentation="list"?>
      <?dbhtml list-presentation="table"?>

      <varlistentry id="addbib">
        <term><command>addbib</command></term>
        <listitem>
          <para>
            creates or extends a bibliographic database
          </para>
          <indexterm zone="heirloom-doctools addbib">
            <primary sortas="b-addbib">addbib</primary>
          </indexterm>
        </listitem>
      </varlistentry>

      <varlistentry id="checkeq">
        <term><command>checkeq</command></term>
        <listitem>
          <para>
            reports missing or unbalanced delimiters and .EQ/.EN pairs
          </para>
          <indexterm zone="heirloom-doctools checkeq">
            <primary sortas="b-checkeq">checkeq</primary>
          </indexterm>
        </listitem>
      </varlistentry>

      <varlistentry id="checknr">
        <term><command>checknr</command></term>
        <listitem>
          <para>
            checks nroff/troff files
          </para>
          <indexterm zone="heirloom-doctools checknr">
            <primary sortas="b-checknr">checknr</primary>
          </indexterm>
        </listitem>
      </varlistentry>

      <varlistentry id="col">
        <term><command>col</command></term>
        <listitem>
          <para>
            filters reverse line feeds
          </para>
          <indexterm zone="heirloom-doctools col">
            <primary sortas="b-col">col</primary>
          </indexterm>
        </listitem>
      </varlistentry>

      <varlistentry id="dhtml">
        <term><command>dhtml</command></term>
        <listitem>
          <para>
            is the HTML postprocessor for <command>troff</command>
          </para>
          <indexterm zone="heirloom-doctools dhtml">
            <primary sortas="b-dhtml">dhtml</primary>
          </indexterm>
        </listitem>
      </varlistentry>

      <varlistentry id="dpost">
        <term><command>dpost</command></term>
        <listitem>
          <para>
            is the PostScript preprocessor for <command>troff</command>
          </para>
          <indexterm zone="heirloom-doctools dpost">
            <primary sortas="b-dpost">dpost</primary>
          </indexterm>
        </listitem>
      </varlistentry>

      <varlistentry id="eqn">
        <term><command>eqn</command></term>
        <listitem>
          <para>
            is the <command>troff</command> preprocessor for typesetting
            mathematics on a photo‐typesetter
          </para>
          <indexterm zone="heirloom-doctools eqn">
            <primary sortas="b-eqn">eqn</primary>
          </indexterm>
        </listitem>
      </varlistentry>

      <varlistentry id="grap">
        <term><command>grap</command></term>
        <listitem>
          <para>
            is the <command>pic</command> preprocessor for drawing graphs
          </para>
          <indexterm zone="heirloom-doctools grap">
            <primary sortas="b-grap">grap</primary>
          </indexterm>
        </listitem>
      </varlistentry>

      <varlistentry id="hunt">
        <term><command>hunt</command></term>
        <listitem>
          <para>
            searches an index made by <command>indxbib</command> and delivers
            the items
          </para>
          <indexterm zone="heirloom-doctools hunt">
            <primary sortas="b-hunt">hunt</primary>
          </indexterm>
        </listitem>
      </varlistentry>

      <varlistentry id="indxbib">
        <term><command>indxbib</command></term>
        <listitem>
          <para>
            builds an inverted index for a bibliography
          </para>
          <indexterm zone="heirloom-doctools indxbib">
            <primary sortas="b-indxbib">indxbib</primary>
          </indexterm>
        </listitem>
      </varlistentry>

      <varlistentry id="inv">
        <term><command>inv</command></term>
        <listitem>
          <para>
            makes an index from a set of keys
          </para>
          <indexterm zone="heirloom-doctools inv">
            <primary sortas="b-inv">inv</primary>
          </indexterm>
        </listitem>
      </varlistentry>

      <varlistentry id="lookbib">
        <term><command>lookbib</command></term>
        <listitem>
          <para>
            uses an inverted index made by <command>indxbib</command> to find
            sets of bibliographic references
          </para>
          <indexterm zone="heirloom-doctools lookbib">
            <primary sortas="b-lookbib">lookbib</primary>
          </indexterm>
        </listitem>
      </varlistentry>

      <varlistentry id="mkey">
        <term><command>mkey</command></term>
        <listitem>
          <para>
            isolates keys from input files
          </para>
          <indexterm zone="heirloom-doctools mkey">
            <primary sortas="b-mkey">mkey</primary>
          </indexterm>
        </listitem>
      </varlistentry>

      <varlistentry id="neqn">
        <term><command>neqn</command></term>
        <listitem>
          <para>
            is the <command>troff</command> preprocessor for typesetting
            mathematics on a terminal
          </para>
          <indexterm zone="heirloom-doctools neqn">
            <primary sortas="b-neqn">neqn</primary>
          </indexterm>
        </listitem>
      </varlistentry>

      <varlistentry id="nroff">
        <term><command>nroff</command></term>
        <listitem>
          <para>
            formats documents for display or printing
          </para>
          <indexterm zone="heirloom-doctools nroff">
            <primary sortas="b-nroff">nroff</primary>
          </indexterm>
        </listitem>
      </varlistentry>

      <varlistentry id="otf_info">
        <term><command>otf_info</command></term>
        <listitem>
          <para>
            dumps contents of OpenType font files
          </para>
          <indexterm zone="heirloom-doctools otf_info">
            <primary sortas="b-otf_info">otf_info</primary>
          </indexterm>
        </listitem>
      </varlistentry>

      <varlistentry id="pic">
        <term><command>pic</command></term>
        <listitem>
          <para>
            is the <command>troff</command> preprocessor for drawing pictures
          </para>
          <indexterm zone="heirloom-doctools pic">
            <primary sortas="b-pic">pic</primary>
          </indexterm>
        </listitem>
      </varlistentry>

      <varlistentry id="picpack">
        <term><command>picpack</command></term>
        <listitem>
          <para>
            is the PostScript picture packing preprocessor
          </para>
          <indexterm zone="heirloom-doctools picpack">
            <primary sortas="b-picpack">picpack</primary>
          </indexterm>
        </listitem>
      </varlistentry>

      <varlistentry id="pm">
        <term><command>pm</command></term>
        <listitem>
          <para>
            is the page justifier for the mpm <command>troff</command> macro
            package
          </para>
          <indexterm zone="heirloom-doctools pm">
            <primary sortas="b-pm">pm</primary>
          </indexterm>
        </listitem>
      </varlistentry>

      <varlistentry id="ptx">
        <term><command>ptx</command></term>
        <listitem>
          <para>
            generates a permuted index
          </para>
          <indexterm zone="heirloom-doctools ptx">
            <primary sortas="b-ptx">ptx</primary>
          </indexterm>
        </listitem>
      </varlistentry>

      <varlistentry id="refer">
        <term><command>refer</command></term>
        <listitem>
          <para>
            finds and inserts literature references in documents
          </para>
          <indexterm zone="heirloom-doctools refer">
            <primary sortas="b-refer">refer</primary>
          </indexterm>
        </listitem>
      </varlistentry>

      <varlistentry id="roffbib">
        <term><command>roffbib</command></term>
        <listitem>
          <para>
            prints out all records in a bibliographic database
          </para>
          <indexterm zone="heirloom-doctools roffbib">
            <primary sortas="b-roffbib">roffbib</primary>
          </indexterm>
        </listitem>
      </varlistentry>

      <varlistentry id="runinv">
        <term><command>runinv</command></term>
        <listitem>
          <para>
            is a demonstration script for <command>inv</command>
          </para>
          <indexterm zone="heirloom-doctools runinv">
            <primary sortas="b-runinv">runinv</primary>
          </indexterm>
        </listitem>
      </varlistentry>

      <varlistentry id="soelim">
        <term><command>soelim</command></term>
        <listitem>
          <para>
            eliminates .SO's from <command>nroff</command> input
          </para>
          <indexterm zone="heirloom-doctools soelim">
            <primary sortas="b-soelim">soelim</primary>
          </indexterm>
        </listitem>
      </varlistentry>

      <varlistentry id="sortbib">
        <term><command>sortbib</command></term>
        <listitem>
          <para>
            sorts a bibliographic database
          </para>
          <indexterm zone="heirloom-doctools sortbib">
            <primary sortas="b-sortbib">sortbib</primary>
          </indexterm>
        </listitem>
      </varlistentry>

      <varlistentry id="ta">
        <term><command>ta</command></term>
        <listitem>
          <para>
            drives an HP2621 terminal to see stuff quickly
          </para>
          <indexterm zone="heirloom-doctools ta">
            <primary sortas="b-ta">ta</primary>
          </indexterm>
        </listitem>
      </varlistentry>

      <varlistentry id="tbl">
        <term><command>tbl</command></term>
        <listitem>
          <para>
            formats tables for <command>nroff</command> or
            <command>troff</command>
          </para>
          <indexterm zone="heirloom-doctools tbl">
            <primary sortas="b-tbl">tbl</primary>
          </indexterm>
        </listitem>
      </varlistentry>

      <varlistentry id="troff">
        <term><command>troff</command></term>
        <listitem>
          <para>
            typesets or formats documents
          </para>
          <indexterm zone="heirloom-doctools troff">
            <primary sortas="b-troff">troff</primary>
          </indexterm>
        </listitem>
      </varlistentry>

      <varlistentry id="vfontedpr">
        <term><command>vfontedpr</command></term>
        <listitem>
          <para>
            is the preprocessor for <command>vgrind</command>
          </para>
          <indexterm zone="heirloom-doctools vfontedpr">
            <primary sortas="b-vfontedpr">vfontedpr</primary>
          </indexterm>
        </listitem>
      </varlistentry>

      <varlistentry id="vgrind">
        <term><command>vgrind</command></term>
        <listitem>
          <para>
            prints nice listings of programs
          </para>
          <indexterm zone="heirloom-doctools vgrind">
            <primary sortas="b-vgrind">vgrind</primary>
          </indexterm>
        </listitem>
      </varlistentry>

    </variablelist>

  </sect2>

