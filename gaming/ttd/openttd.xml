<sect1 id="openttd" xreflabel="OpenTTD-&openttd-version;">
  <?dbhtml filename="openttd.html"?>

  <title>OpenTTD-&openttd-version;</title>

  <indexterm zone="openttd">
    <primary sortas="a-openttd">OpenTTD</primary>
  </indexterm>

  <sect2 role="package">
    <title>Introduction to OpenTTD</title>

    <para>
      The OpenTTD package is an open source and
      improved-upon version of Transportation Tycoon Deluxe.
    </para>

    &long-build-time;

    <itemizedlist spacing="compact">
      <listitem>
        <para>
          Download: <ulink url="&openttd-download;"/>
        </para>
      </listitem>
    </itemizedlist>

    <bridgehead renderas="sect3">OpenTTD Dependencies</bridgehead>

    <bridgehead renderas="sect4">Required</bridgehead>
    <para role="required">
      &sdl2;
    </para>

    <bridgehead renderas="sect4">Required (for clients; not needed for
      servers)</bridgehead>
    <para role="required">
      <ulink url="&blfs-svn;/general/fontconfig.html">Fontconfig</ulink>,
      <ulink url="&blfs-svn;/general/freetype2.html">FreeType2</ulink>, and
      <ulink url="&blfs-svn;/general/harfbuzz.html">HarfBuzz</ulink>
      (with <ulink url="&blfs-svn;/general/icu.html">ICU</ulink>)
    </para>

    <bridgehead renderas="sect4">Recommended</bridgehead>
    <para role="recommended">
      <ulink url="&blfs-svn;/basicnet/curl.html">cURL</ulink>,
      <ulink url="&blfs-svn;/x/hicolor-icon-theme.html">hicolor-icon-theme</ulink>,
      and <ulink url="&blfs-svn;/general/libpng.html">libpng</ulink>
    </para>

    <bridgehead renderas="sect4">Optional</bridgehead>
    <para role="optional">
      <ulink
        url="https://chromium.googlesource.com/breakpad/breakpad">breakpad</ulink>,
      <ulink url="&blfs-svn;/general/doxygen.html">Doxygen</ulink>, and
      <xref linkend="fluidsynth"/>
    </para>

  </sect2>

  <sect2 role="installation">
    <title>Installation of OpenTTD</title>

    <para>
      Install OpenTTD by running the following
      commands:
    </para>

<screen><userinput>mkdir build &amp;&amp;
cd    build &amp;&amp;

cmake -D CMAKE_INSTALL_PREFIX=/usr   \
      -D CMAKE_BUILD_TYPE=Release    \
      -W no-dev -G Ninja .. &amp;&amp;

ninja</userinput></screen>

    <para>
      Now, as the &root; user:
    </para>

<screen role="root"><userinput>ninja install &amp;&amp;
mv -v /usr/share/doc/openttd{,-&openttd-version;}</userinput></screen>

    <note><para>
      OpenTTD will install into <filename
      class="directory">/usr/games</filename>.
    </para></note>

  </sect2>

